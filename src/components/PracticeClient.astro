---
interface ExerciseSummary {
  id: string;
  slug: string;
  title: string;
  level: string;
  skill: string;
}

interface Props {
  exercises: ExerciseSummary[];
}

const { exercises } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<section class="practice-stack" data-library={JSON.stringify(exercises)}>
  <section class="panel practice-options">
    <div class="section-head">
      <div>
        <p class="eyebrow">Dojo practice</p>
        <h1>Choose how you want to train today</h1>
      </div>
      <span class="badge">Attempt first · 先に挑戦</span>
    </div>
    <div class="option-grid option-grid-compact">
      <article class="choice-card">
        <p class="eyebrow">Curated</p>
        <h3>Fixed lesson-aligned list</h3>
        <p>Use an authored sequence to reinforce the current curriculum in a calm order.</p>
      </article>
      <article class="choice-card">
        <p class="eyebrow">Generated</p>
        <h3>New drill list</h3>
        <p>Create a replayable session with its own ID so you can resume or replay the same list later.</p>
      </article>
      <article class="choice-card">
        <p class="eyebrow">Review</p>
        <h3>Resume from history</h3>
        <p>Continue where you stopped, compare scores, or replay a past list with a fresh answer sheet.</p>
      </article>
    </div>
    <div class="practice-preset-row">
      <button class="button button-secondary practice-preset" data-preset="warmup">Warm-up</button>
      <button class="button button-secondary practice-preset" data-preset="practice">Practice</button>
      <button class="button button-secondary practice-preset" data-preset="review">Review</button>
      <button class="button button-secondary practice-preset" data-preset="speed">Speed</button>
      <button class="button button-secondary practice-preset" data-preset="mental">Mental</button>
    </div>
    <div class="practice-grid">
      <div class="stack-sm subtle-panel practice-config-panel">
        <p class="eyebrow">Session shape</p>
        <label class="stack-sm">
          <span>Practice format · 形式</span>
          <select id="session-format" class="select">
            <option value="single">One by one</option>
            <option value="sheet">Question sheet</option>
          </select>
        </label>
        <label class="stack-sm">
          <span>Session type · 稽古</span>
          <select id="session-type" class="select">
            <option value="curated">Curated list</option>
            <option value="generated">Generated drill</option>
          </select>
        </label>
        <label class="stack-sm">
          <span>Level focus · 段階</span>
          <select id="session-level" class="select">
            <option value="L0">L0 Foundations</option>
            <option value="L1">L1 Beginner</option>
            <option value="L2">L2 Complements</option>
            <option value="L3">L3 Mixed fluency</option>
            <option value="L4">L4 Multiplication &amp; division</option>
            <option value="L5">L5 Mastery review</option>
          </select>
        </label>
        <label class="stack-sm">
          <span>List length · 問題数</span>
          <select id="session-length" class="select">
            <option value="5">5 questions</option>
            <option value="10" selected>10 questions</option>
            <option value="15">15 questions</option>
            <option value="20">20 questions</option>
          </select>
        </label>
      </div>
      <div class="stack-sm subtle-panel practice-config-panel">
        <p class="eyebrow">Answering</p>
        <label class="stack-sm">
          <span>Check style · 確認</span>
          <select id="check-mode" class="select">
            <option value="verify">Verify only</option>
            <option value="final">Verify and show final number</option>
            <option value="steps">Verify and show steps</option>
            <option value="self-mark">Self-mark after reveal</option>
          </select>
        </label>
        <label class="stack-sm">
          <span>Timer · 時間</span>
          <select id="timer-mode" class="select">
            <option value="off">Timer off</option>
            <option value="on">Timer on</option>
          </select>
        </label>
        <label class="stack-sm">
          <span>Question style · 問題</span>
          <select id="question-style" class="select">
            <option value="mixed">Mixed</option>
            <option value="visual">Visual first</option>
            <option value="mental">Mental prompt</option>
            <option value="adaptive">Adaptive weak-area</option>
          </select>
        </label>
        <label class="stack-sm">
          <span>Term count · 項数</span>
          <select id="term-count" class="select">
            <option value="auto" selected>Auto</option>
            <option value="2">2 terms</option>
            <option value="3">3 terms</option>
            <option value="4">4 terms</option>
          </select>
        </label>
        <div class="button-row">
          <button class="button" id="start-session">Start new session</button>
          <button class="button button-secondary" id="resume-latest">Resume latest</button>
        </div>
        <label class="stack-sm">
          <span>Resume by session ID · 続き</span>
          <input id="session-id-input" class="input" type="text" placeholder="Paste a saved session ID" />
        </label>
        <button class="button button-secondary" id="resume-by-id">Open saved ID</button>
      </div>
    </div>
    <div class="subtle-panel practice-current-setup">
      <strong>Current setup</strong>
      <span id="practice-current-setup-copy" class="muted small">single · curated · L0 · 10 questions · mixed · auto terms · timer off</span>
    </div>
    <div class="subtle-panel practice-mode-guide">
      <strong id="practice-guide-title">Recommended use</strong>
      <p id="practice-guide-copy" class="muted small">Use this setup for short focused repetition before moving to sheets or review.</p>
    </div>
    <div class="practice-quick-paths">
      <button class="button button-secondary practice-preset" data-preset="warmup">Quick warm-up</button>
      <button class="button button-secondary practice-preset" data-preset="review">Review weak areas</button>
      <a class="button button-secondary" href={`${base}worksheets`}>Open worksheet</a>
    </div>
  </section>

  <div class="practice-grid practice-main-grid">
    <section class="panel question-shell">
      <div class="section-head">
        <div>
          <p class="eyebrow">Current session</p>
          <h2 id="session-title">No session selected yet</h2>
        </div>
      </div>
      <div class="practice-session-stats">
        <article class="stat-card stat-card-soft"><span id="session-progress">0 / 0</span><small>Progress</small></article>
        <article class="stat-card stat-card-soft"><span id="session-score">—</span><small>Score</small></article>
        <article class="stat-card stat-card-soft"><span id="session-timer">Off</span><small>Timer</small></article>
      </div>
      <div class="practice-session-meta muted small">
        <div id="session-id">Session ID —</div>
        <div id="session-adaptive-note">Adaptive note —</div>
      </div>

      <div id="visual-mount" class="subtle-panel visual-stage" hidden></div>
      <div id="single-session-view" class="subtle-panel question-stage">
        <p class="eyebrow">Question</p>
        <h3 id="question-title">Choose a session to begin.</h3>
        <p id="question-prompt" class="muted">Curated lists follow the lessons; generated lists create replayable arithmetic practice.</p>
        <div class="practice-empty-note" id="practice-empty-note">
          <strong>Recommended start</strong>
          <p class="muted">Pick a preset above, then start one short session before moving into longer sheets.</p>
          <div class="button-row button-row-compact">
            <button class="button" id="empty-warmup">Use warm-up preset</button>
            <a class="button button-secondary" href={`${base}worksheets`}>Open worksheets</a>
          </div>
        </div>
        <div class="question-flow-note">
          <span class="review-chip">1. Solve first</span>
          <span class="review-chip">2. Write your response</span>
          <span class="review-chip">3. Verify or reveal the answer</span>
        </div>
        <label class="stack-sm answer-stack">
          <span>Your response · 記入</span>
          <input id="answer-input" class="input" type="text" inputmode="numeric" placeholder="Write your response before checking" />
        </label>

        <div class="button-row button-row-compact">
          <button class="button" id="verify-answer">Verify response</button>
          <button class="button button-secondary" id="reveal-final">Reveal answer</button>
          <button class="button button-secondary" id="reveal-steps">Reveal method</button>
          <button class="button button-secondary" id="next-question">Save and continue</button>
        </div>
      </div>

      <div id="sheet-session-view" class="subtle-panel sheet-stage" hidden>
        <div class="section-head">
          <div>
            <p class="eyebrow">Soroban sheet · 用紙</p>
            <h3>Practice several questions at once</h3>
          </div>
          <button class="button button-secondary" id="print-sheet">Print sheet</button>
        </div>
        <div id="sheet-list" class="sheet-list"></div>
        <div class="button-row button-row-compact">
          <button class="button" id="check-sheet">Check sheet answers</button>
          <button class="button button-secondary" id="reveal-sheet-answers">Reveal sheet answers</button>
          <button class="button button-secondary" id="save-sheet">Save sheet progress</button>
        </div>
      </div>

      <div id="feedback-panel" class="reveal-panel" hidden role="status" aria-live="polite"></div>
      <div id="steps-panel" class="reveal-panel" hidden aria-live="polite"></div>
      <details class="practice-help-block">
        <summary>How to use this session</summary>
        <div class="review-chip-row">
          <span class="review-chip">Verify only if you just want confirmation</span>
          <span class="review-chip">Reveal the final number when you want a quick check</span>
          <span class="review-chip">Reveal steps when you want to study the method</span>
          <span class="review-chip">Resume or replay later with the saved session ID</span>
        </div>
      </details>
    </section>

    <aside class="panel stack-sm side-panel">
      <details class="collapsible-block">
        <summary>
          <span>
            <p class="eyebrow">Session history</p>
            <h2>Resume or replay</h2>
          </span>
        </summary>
        <div id="history-list" class="session-list">
          <p class="muted">Your saved sessions will appear here.</p>
        </div>
      </details>

      <details class="collapsible-block">
        <summary>
          <span>
            <p class="eyebrow">Exercise library</p>
            <h3>Study by lesson if you prefer</h3>
          </span>
        </summary>
        <ul class="list-clean compact-library">
          {exercises.slice(0, 6).map((exercise) => (
            <li>
              <strong>{exercise.title}</strong>
              <div class="meta-row">
                <span>{exercise.level}</span>
                <span>{exercise.skill}</span>
              </div>
              <a class="text-link" href={`${base}exercises/${exercise.slug}`}>Open library item →</a>
            </li>
          ))}
        </ul>
      </details>

      <div class="subtle-panel sora-sheet-note">
        <p class="eyebrow">Soroban sheets</p>
        <p class="muted">Use sheet mode when you want many questions at once, or print worksheets for desk-style repetition.</p>
      </div>
    </aside>
  </div>
</section>

<script is:inline>
  const SESSION_KEY = 'soroban-dojo:practice-sessions';
  const TIMER_KEY = 'soroban-dojo:timer-history';
  const EXERCISE_STATE_KEY = 'soroban-dojo:exercise-states';
  let currentSession = null;
  let timerInterval = null;
  let questionStartedAt = null;
  let activeTimerKey = null;
  const audioWindow = typeof window !== 'undefined' ? /** @type {any} */ (window) : null;
  const AudioContextCtor = audioWindow
    ? audioWindow.AudioContext || (audioWindow).webkitAudioContext || null
    : null;
  const audioCtx = AudioContextCtor ? new AudioContextCtor() : null;
  const playTone = (type) => {
    if (!audioCtx) return;
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    osc.type = 'sine';
    const start = audioCtx.currentTime;
    const freqA = type === 'success' ? 660 : 280;
    const freqB = type === 'success' ? 880 : 220;
    osc.frequency.setValueAtTime(freqA, start);
    osc.frequency.linearRampToValueAtTime(freqB, start + 0.16);
    gain.gain.setValueAtTime(0.0001, start);
    gain.gain.linearRampToValueAtTime(0.028, start + 0.02);
    gain.gain.exponentialRampToValueAtTime(0.0001, start + 0.2);
    osc.connect(gain);
    gain.connect(audioCtx.destination);
    osc.start();
    osc.stop(start + 0.22);
  };

  const curatedBank = [
    { level: 'L0', title: 'Add 1 and 2', prompt: 'Start from 1. Add 2. What is the final value?', answer: 3, steps: ['Start at 1.', 'Add 2.', '1 + 2 = 3.'], visualValue: 3 },
    { level: 'L0', title: 'Add 2 and 2', prompt: 'Start from 2. Add 2. What is the final value?', answer: 4, steps: ['Start at 2.', 'Add 2.', '2 + 2 = 4.'], visualValue: 4 },
    { level: 'L0', title: 'Subtract 1 from 4', prompt: 'Start from 4. Subtract 1. What is the final value?', answer: 3, steps: ['Start at 4.', 'Subtract 1.', '4 - 1 = 3.'], visualValue: 3 },
    { level: 'L1', title: 'Add two and three', prompt: 'Start from 2. Add 3.', answer: 5, steps: ['Start at 2.', 'Add 3.', 'The rod becomes the clean five shape.', '2 + 3 = 5.'], visualValue: 5 },
    { level: 'L1', title: 'Add four and four', prompt: 'Start from 4. Add 4.', answer: 8, steps: ['Start at 4.', 'Add 4.', 'Read the rod as 5 + 3.', '4 + 4 = 8.'], visualValue: 8 },
    { level: 'L1', title: 'Subtract two from eight', prompt: 'Start from 8. Subtract 2.', answer: 6, steps: ['Start at 8.', 'Remove 2.', 'Read the rod again: 6.', '8 - 2 = 6.'], visualValue: 6 },
    { level: 'L2', title: 'Complement to five', prompt: 'You are at 2. Which number completes the rod to 5?', answer: 3, steps: ['Ask what 2 needs to become 5.', 'The missing part is 3.', '2 and 3 are a complement pair to 5.'], visualValue: 5 },
    { level: 'L2', title: 'Complement to ten', prompt: 'You are at 7. Which number completes the value to 10?', answer: 3, steps: ['Ask what 7 needs to become 10.', 'The missing part is 3.', '7 and 3 are a complement pair to 10.'], visualValue: 10 },
    { level: 'L2', title: 'Add three to seven', prompt: 'Start from 7. Add 3.', answer: 10, steps: ['Start at 7.', 'Notice 7 needs 3 to become 10.', 'Complete the ten.', '7 + 3 = 10.'], visualValue: 10 },
    { level: 'L2', title: 'Add three to two', prompt: 'Start from 2. Add 3 using the complement to 5.', answer: 5, steps: ['Start at 2.', 'Use the complement pair 2 and 3.', 'Move to the clean five shape.', '2 + 3 = 5.'], visualValue: 5 },
    { level: 'L5', title: 'Mental sequence warmup', prompt: 'Without moving beads, solve 18 + 7 + 5.', answer: 30, steps: ['Start at 18.', 'Add 7 to reach 25.', 'Add 5 to reach 30.'], visualValue: 30 },
    { level: 'L5', title: 'Mental mixed review', prompt: 'Without moving beads, solve 24 - 6 + 8.', answer: 26, steps: ['Start at 24.', 'Subtract 6 to reach 18.', 'Add 8 to reach 26.'], visualValue: 26 },
  ];

  const byId = (id) => document.getElementById(id);
  const readSessions = () => {
    try { return JSON.parse(localStorage.getItem(SESSION_KEY) || '[]'); } catch { return []; }
  };
  const writeSessions = (sessions) => localStorage.setItem(SESSION_KEY, JSON.stringify(sessions));
  const appendTimer = (entry) => {
    try {
      const current = JSON.parse(localStorage.getItem(TIMER_KEY) || '[]');
      current.push(entry);
      localStorage.setItem(TIMER_KEY, JSON.stringify(current));
    } catch {}
  };
  const readExerciseStates = () => {
    try { return JSON.parse(localStorage.getItem(EXERCISE_STATE_KEY) || '{}'); } catch { return {}; }
  };
  const writeExerciseStates = (state) => localStorage.setItem(EXERCISE_STATE_KEY, JSON.stringify(state));
  const readWeakAreas = () => {
    const states = readExerciseStates();
    return Object.values(states).reduce((acc, entry) => {
      if (entry?.status !== 'needs-review') return acc;
      const sessionId = entry.sessionId || '';
      if (sessionId.includes('L5')) acc.mental += 1;
      else if (sessionId.includes('L4')) acc.multiplication += 1;
      else if (sessionId.includes('L2')) acc.complements += 1;
      else acc.arithmetic += 1;
      return acc;
    }, { arithmetic: 0, complements: 0, multiplication: 0, mental: 0 });
  };

  const applyPracticeLevelDefaults = (level) => {
    const format = byId('session-format');
    const length = byId('session-length');
    const checkMode = byId('check-mode');
    const questionStyle = byId('question-style');
    const termCount = byId('term-count');
    if (!format || !length || !checkMode || !questionStyle || !termCount) return;
    if (level === 'L0') {
      format.value = 'single';
      length.value = '5';
      checkMode.value = 'final';
      questionStyle.value = 'visual';
      termCount.value = '2';
    } else if (level === 'L1') {
      format.value = 'single';
      length.value = '10';
      checkMode.value = 'final';
      questionStyle.value = 'mixed';
      termCount.value = '2';
    } else if (level === 'L2') {
      format.value = 'single';
      length.value = '10';
      checkMode.value = 'steps';
      questionStyle.value = 'mixed';
      termCount.value = '3';
    } else if (level === 'L3') {
      format.value = 'sheet';
      length.value = '10';
      checkMode.value = 'verify';
      questionStyle.value = 'mixed';
      termCount.value = '3';
    } else if (level === 'L4') {
      format.value = 'sheet';
      length.value = '15';
      checkMode.value = 'verify';
      questionStyle.value = 'mixed';
      termCount.value = '3';
    } else {
      format.value = 'single';
      length.value = '10';
      checkMode.value = 'steps';
      questionStyle.value = 'mental';
      termCount.value = '4';
    }
  };

  const describeAdaptivePractice = (level) => {
    const weak = readWeakAreas();
    if (level === 'L5' || weak.mental >= weak.arithmetic) return 'Adaptive focus: mental / anzan recovery';
    if (weak.multiplication > weak.arithmetic && level === 'L4') return 'Adaptive focus: multiplication / division repair';
    if (weak.complements > weak.arithmetic && level === 'L2') return 'Adaptive focus: complements and balancing';
    return 'Adaptive focus: arithmetic rhythm and accuracy';
  };

  const makeId = () => `dojo-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 8)}`;
  const simpleSlug = (value) => value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');
  const hash = (value) => Array.from(value).reduce((acc, char) => ((acc << 5) - acc + char.charCodeAt(0)) | 0, 0);
  const createRng = (seed) => {
    let state = Math.abs(hash(seed)) || 1;
    return () => {
      state = (state * 1664525 + 1013904223) % 4294967296;
      return state / 4294967296;
    };
  };
  const pick = (rng, items) => items[Math.floor(rng() * items.length)];

    const resolveAdaptiveStyle = (level, questionStyle) => {
      if (questionStyle !== 'adaptive') return questionStyle;
      const weak = readWeakAreas();
      if (level === 'L5' || weak.mental >= weak.arithmetic) return 'mental';
      if (weak.multiplication > weak.arithmetic && level === 'L4') return 'mixed';
      if (weak.complements > weak.arithmetic && level === 'L2') return 'mixed';
      return 'visual';
    };

  const resolveTermCount = (level, termCount) => {
    if (termCount !== 'auto') return Number(termCount);
    if (level === 'L0' || level === 'L1') return 2;
    if (level === 'L2') return 3;
    if (level === 'L3' || level === 'L4') return 3;
    return 4;
  };

  const buildSequence = (rng, start, stepCount, maxStep) => {
    const ops = [];
    let total = start;
    for (let i = 0; i < stepCount; i += 1) {
      const add = rng() > 0.45;
      const value = Math.max(1, Math.floor(rng() * maxStep) + 1);
      if (!add && total - value <= 0) {
        total += value;
        ops.push({ op: '+', value });
      } else if (add) {
        total += value;
        ops.push({ op: '+', value });
      } else {
        total -= value;
        ops.push({ op: '-', value });
      }
    }
    return { ops, total };
  };

  const buildGeneratedQuestion = (level, index, rng, questionStyle = 'mixed', termCount = 'auto') => {
    const effectiveStyle = resolveAdaptiveStyle(level, questionStyle);
    const terms = resolveTermCount(level, termCount);
    if (level === 'L0') {
      const a = Math.floor(rng() * 4) + 1;
      const b = Math.floor(rng() * (5 - a)) + 1;
      const answer = a + b;
      return {
        id: `g-${level}-${index}`,
        progressKey: `generated-${simpleSlug(`${level}-${answer}`)}`,
        title: `Generated starter sum ${index + 1}`,
        prompt: effectiveStyle === 'visual' ? `On one rod, start from ${a}. Add ${b}. What final value do you read?` : `Start from ${a}. Add ${b}. What is the final value?`,
        answer,
        visualValue: answer,
        steps: [`Start at ${a}.`, `Add ${b}.`, `${a} + ${b} = ${answer}.`],
      };
    }
    if (level === 'L1') {
      const a = Math.floor(rng() * 8) + 1;
      const b = Math.floor(rng() * (9 - a)) + 1;
      const subtract = effectiveStyle === 'mental' ? false : rng() > 0.5;
      if (subtract) {
        const start = a + b;
        return {
          id: `g-${level}-${index}`,
          progressKey: `generated-${simpleSlug(`${level}-${start}-${b}-${a}`)}`,
          title: `Generated subtraction ${index + 1}`,
          prompt: `Start from ${start}. Subtract ${b}. What is the final value?`,
          answer: a,
          visualValue: a,
          steps: [`Start at ${start}.`, `Subtract ${b}.`, `${start} - ${b} = ${a}.`],
        };
      }
      return {
        id: `g-${level}-${index}`,
        progressKey: `generated-${simpleSlug(`${level}-${a}-${b}-${a + b}`)}`,
        title: `Generated addition ${index + 1}`,
        prompt: `Start from ${a}. Add ${b}. What is the final value?`,
        answer: a + b,
        visualValue: a + b,
        steps: [`Start at ${a}.`, `Add ${b}.`, `${a} + ${b} = ${a + b}.`],
      };
    }
    if (level === 'L3') {
      const a = Math.floor(rng() * 300) + 100;
      const sequence = buildSequence(rng, a, Math.max(2, terms - 1), 80);
      const promptOps = sequence.ops.map(({ op, value }) => `${op} ${value}`).join(' ');
      return {
        id: `g-${level}-${index}`,
        progressKey: `generated-${simpleSlug(`${level}-${a}-${promptOps}-${sequence.total}`)}`,
        title: `Generated sequence drill ${index + 1}`,
        prompt: `Solve this sequence carefully: ${a} ${promptOps}.`,
        answer: sequence.total,
        visualValue: sequence.total,
        steps: [`Start at ${a}.`, ...sequence.ops.map(({ op, value }) => `${op === '+' ? 'Add' : 'Subtract'} ${value}.`), `Final value: ${sequence.total}.`],
      };
    }
    if (level === 'L5' || effectiveStyle === 'mental') {
      const a = Math.floor(rng() * 60) + 20;
      const sequence = buildSequence(rng, a, Math.max(2, terms - 1), 30);
      const promptOps = sequence.ops.map(({ op, value }) => `${op} ${value}`).join(' ');
      return {
        id: `g-${level}-${index}`,
        progressKey: `generated-${simpleSlug(`${level}-${a}-${promptOps}-${sequence.total}`)}`,
        title: `Generated mental drill ${index + 1}`,
        prompt: `Without moving beads, solve ${a} ${promptOps}.`,
        answer: sequence.total,
        visualValue: sequence.total,
        steps: [`Start at ${a}.`, ...sequence.ops.map(({ op, value }) => `${op === '+' ? 'Add' : 'Subtract'} ${value}.`), `Final value: ${sequence.total}.`],
      };
    }
    const base = Math.floor(rng() * 8) + 1;
    const answer = 10 - base;
      return {
      id: `g-${level}-${index}`,
      progressKey: `generated-${simpleSlug(`${level}-${base}-${answer}`)}`,
      title: `Generated complement ${index + 1}`,
        prompt: effectiveStyle === 'mental' ? `Without moving beads yet, what number completes ${base} to 10?` : `You are at ${base}. Which number completes the value to 10?`,
      answer,
      visualValue: 10,
      steps: [`Start at ${base}.`, `Ask what ${base} needs to become 10.`, `The missing value is ${answer}.`],
    };
  };

  const buildCuratedQuestions = (level, length, sessionId) => {
    const allowed = curatedBank.filter((item) => item.level === level || (level === 'L2' && ['L0', 'L1', 'L2'].includes(item.level)) || (level === 'L1' && ['L0', 'L1'].includes(item.level)) || (level === 'L5' && ['L2','L3','L4','L5'].includes(item.level)));
    const rng = createRng(sessionId);
    return Array.from({ length }, (_, index) => {
      const source = pick(rng, allowed);
      return { ...source, id: `${sessionId}-c-${index}`, progressKey: `curated-${simpleSlug(source.title)}` };
    });
  };

  const buildGeneratedQuestions = (level, length, sessionId, questionStyle, termCount) => {
    const rng = createRng(sessionId);
    return Array.from({ length }, (_, index) => buildGeneratedQuestion(level, index, rng, questionStyle, termCount));
  };

  const presets = {
    warmup: { format: 'single', type: 'curated', level: 'L0', length: '5', checkMode: 'final', timerMode: 'off', questionStyle: 'visual', termCount: '2' },
    practice: { format: 'single', type: 'generated', level: 'L2', length: '10', checkMode: 'verify', timerMode: 'off', questionStyle: 'mixed', termCount: '3' },
    review: { format: 'sheet', type: 'generated', level: 'L2', length: '10', checkMode: 'steps', timerMode: 'off', questionStyle: 'adaptive', termCount: '3' },
    speed: { format: 'single', type: 'generated', level: 'L3', length: '20', checkMode: 'verify', timerMode: 'on', questionStyle: 'mixed', termCount: '3' },
    mental: { format: 'single', type: 'generated', level: 'L5', length: '10', checkMode: 'steps', timerMode: 'off', questionStyle: 'mental', termCount: '4' },
  };

  const syncPracticeSetupCopy = () => {
    const target = byId('practice-current-setup-copy');
    const guideTitle = byId('practice-guide-title');
    const guideCopy = byId('practice-guide-copy');
    if (!target) return;
    target.textContent = `${byId('session-format').value} · ${byId('session-type').value} · ${byId('session-level').value} · ${byId('session-length').value} questions · ${byId('question-style').value} · ${byId('term-count').value} terms · ${byId('timer-mode').value}`;
    if (!guideTitle || !guideCopy) return;
    const format = byId('session-format').value;
    const style = byId('question-style').value;
    const level = byId('session-level').value;
    if (format === 'sheet') {
      guideTitle.textContent = 'Best for dense worksheet-style practice';
      guideCopy.textContent = 'Use sheet mode when you want many questions at once, calmer review, or something close to printed drill work.';
    } else if (style === 'mental') {
      guideTitle.textContent = 'Best for mental / anzan focus';
      guideCopy.textContent = 'This setup is tuned for mental work. Solve without moving beads, then verify carefully.';
    } else if (level === 'L0' || level === 'L1') {
      guideTitle.textContent = 'Best for guided fundamentals';
      guideCopy.textContent = 'This setup favors shorter, clearer drills so you can build confidence before increasing length or speed.';
    } else {
      guideTitle.textContent = 'Best for steady mixed practice';
      guideCopy.textContent = 'Use this configuration to keep rhythm while building fluency across several related drill types.';
    }
  };

  const applyPreset = (key) => {
    const preset = presets[key];
    if (!preset) return;
    byId('session-format').value = preset.format;
    byId('session-type').value = preset.type;
    byId('session-level').value = preset.level;
    byId('session-length').value = preset.length;
    byId('check-mode').value = preset.checkMode;
    byId('timer-mode').value = preset.timerMode;
    byId('question-style').value = preset.questionStyle;
    byId('term-count').value = preset.termCount;
    syncPracticeSetupCopy();
  };

  const createSession = ({ type, level, length, checkMode, timerEnabled, format, questionStyle, termCount }) => {
    const sessionId = makeId();
    const questions = type === 'curated'
      ? buildCuratedQuestions(level, length, sessionId)
      : buildGeneratedQuestions(level, length, sessionId, questionStyle, termCount);
    return {
      id: sessionId,
      type,
      level,
      length,
      checkMode,
      timerEnabled,
      format,
      questionStyle,
      termCount,
      createdAt: new Date().toISOString(),
      currentIndex: 0,
      completed: false,
      questions,
      responses: {},
      finalScore: null,
    };
  };

  const persistCurrent = () => {
    if (!currentSession) return;
    const sessions = readSessions();
    const existingIndex = sessions.findIndex((entry) => entry.id === currentSession.id);
    if (existingIndex >= 0) sessions.splice(existingIndex, 1);
    sessions.unshift(currentSession);
    writeSessions(sessions.slice(0, 12));
  };

  const responseForCurrent = () => currentSession?.responses?.[currentSession.currentIndex] || {
    input: '',
    hintsUsed: 0,
    revealedFinal: false,
    revealedSteps: false,
    verified: false,
    correct: false,
    seconds: 0,
  };

  const computeQuestionScore = (response) => {
    if (!response || !response.verified) return 0;
    if (response.correct && !response.revealedFinal && !response.revealedSteps && !response.hintsUsed) return 100;
    if (response.correct && !response.revealedSteps) return 85;
    if (response.correct) return 70;
    if (response.revealedSteps || response.revealedFinal) return 40;
    return 15;
  };

  const computeSessionScore = (session) => {
    const total = session.questions.reduce((sum, _, index) => sum + computeQuestionScore(session.responses[index]), 0);
    return Math.round(total / session.questions.length);
  };

  const stopTimer = () => {
    if (timerInterval) window.clearInterval(timerInterval);
    timerInterval = null;
    if (!currentSession || !currentSession.timerEnabled || !questionStartedAt) return;
    const seconds = Math.max(1, Math.round((Date.now() - questionStartedAt) / 1000));
    const existing = responseForCurrent();
    currentSession.responses[currentSession.currentIndex] = { ...existing, seconds: (existing.seconds || 0) + seconds };
    appendTimer({ id: currentSession.id, questionIndex: currentSession.currentIndex, seconds, endedAt: new Date().toISOString() });
    questionStartedAt = null;
    activeTimerKey = null;
  };

  const syncExerciseProgress = () => {
    if (!currentSession) return;
    const question = currentSession.questions[currentSession.currentIndex];
    const response = responseForCurrent();
    const existing = readExerciseStates();
    existing[question.progressKey || question.id] = {
      status: response.correct ? 'got-it' : 'needs-review',
      sessionId: currentSession.id,
      updatedAt: new Date().toISOString(),
    };
    writeExerciseStates(existing);
  };

  const renderVisual = (value) => {
    const mount = byId('visual-mount');
    mount.replaceChildren();
    if (value === undefined || value === null) {
      mount.hidden = true;
      return;
    }
    const board = document.createElement('div');
    board.className = 'soroban-board';
    String(value).split('').forEach((digitText) => {
      const digit = Number(digitText);
      const rod = document.createElement('div');
      rod.className = 'rod';
      const upper = document.createElement('div');
      upper.className = `bead upper ${digit >= 5 ? 'active' : ''}`;
      rod.appendChild(upper);
      const beam = document.createElement('div');
      beam.className = 'beam';
      rod.appendChild(beam);
      Array.from({ length: 4 }, (_, index) => {
        const bead = document.createElement('div');
        bead.className = `bead lower ${index < digit % 5 ? 'active' : ''}`;
        rod.appendChild(bead);
      });
      board.appendChild(rod);
    });
    mount.appendChild(board);
    mount.hidden = false;
  };

  const renderHistory = () => {
    const historyList = byId('history-list');
    const sessions = readSessions();
    historyList.replaceChildren();
    if (!sessions.length) {
      const note = document.createElement('p');
      note.className = 'muted';
      note.textContent = 'Your saved sessions will appear here.';
      historyList.appendChild(note);
      return;
    }
    sessions.forEach((session) => {
      const card = document.createElement('article');
      card.className = 'session-card';
      const title = document.createElement('strong');
      title.textContent = `${session.type === 'curated' ? 'Curated' : 'Generated'} · ${session.level}`;
      const meta = document.createElement('p');
      meta.className = 'muted small';
      meta.textContent = `${session.id} · ${session.completed ? session.questions.length : session.currentIndex}/${session.questions.length} complete`;
      const score = document.createElement('div');
      score.className = 'score-band';
      score.textContent = session.completed ? `${session.finalScore}/100` : 'In progress';
      const actions = document.createElement('div');
      actions.className = 'button-row';
      const resume = document.createElement('button');
      resume.className = 'button button-secondary';
      resume.textContent = 'Resume';
      resume.addEventListener('click', () => { stopTimer(); currentSession = session; renderSession(); });
      const replay = document.createElement('button');
      replay.className = 'button button-secondary';
      replay.textContent = 'Replay list';
      replay.addEventListener('click', () => {
        stopTimer();
        const copy = {
          ...session,
          id: makeId(),
          createdAt: new Date().toISOString(),
          currentIndex: 0,
          completed: false,
          responses: {},
          finalScore: null,
        };
        currentSession = copy;
        persistCurrent();
        renderHistory();
        renderSession();
      });
      actions.append(resume, replay);
      card.append(title, meta, score, actions);
      historyList.appendChild(card);
    });
  };

  const renderSession = () => {
    const title = byId('session-title');
    const sessionIdLabel = byId('session-id');
    const progress = byId('session-progress');
    const score = byId('session-score');
    const timer = byId('session-timer');
    const adaptiveNote = byId('session-adaptive-note');
    const questionTitle = byId('question-title');
    const questionPrompt = byId('question-prompt');
    const answerInput = byId('answer-input');
    const feedback = byId('feedback-panel');
    const stepsPanel = byId('steps-panel');
    const singleView = byId('single-session-view');
    const sheetView = byId('sheet-session-view');
    const sheetList = byId('sheet-list');
    const emptyNote = byId('practice-empty-note');
    const controls = ['answer-input', 'verify-answer', 'reveal-final', 'reveal-steps', 'next-question'];
    feedback.hidden = true;
    stepsPanel.hidden = true;

    if (!currentSession) {
      title.textContent = 'No session selected yet';
      sessionIdLabel.textContent = 'Session ID —';
      progress.textContent = 'Question 0 / 0';
      score.textContent = 'Score —';
      timer.textContent = 'Timer off';
      adaptiveNote.textContent = 'Adaptive note —';
      questionTitle.textContent = 'Choose a session to begin.';
      questionPrompt.textContent = 'Curated lists follow the lessons; generated lists create replayable arithmetic practice.';
      answerInput.value = '';
      singleView.hidden = false;
      sheetView.hidden = true;
      emptyNote.hidden = false;
      renderVisual(null);
      controls.forEach((id) => { const node = byId(id); if (node) node.disabled = true; });
      activeTimerKey = null;
      return;
    }

    const question = currentSession.questions[currentSession.currentIndex];
    const response = responseForCurrent();
    title.textContent = `${currentSession.type === 'curated' ? 'Curated' : 'Generated'} ${currentSession.level} session`;
    sessionIdLabel.textContent = `Session ID ${currentSession.id}`;
    progress.textContent = `Question ${currentSession.currentIndex + 1} / ${currentSession.questions.length}`;
    score.textContent = `Score ${(currentSession.completed ? currentSession.finalScore : computeSessionScore(currentSession)) || 0}/100`;
    timer.textContent = currentSession.timerEnabled ? 'Timer on' : 'Timer off';
    adaptiveNote.textContent = currentSession.questionStyle === 'adaptive' ? describeAdaptivePractice(currentSession.level) : 'Adaptive note —';
    questionTitle.textContent = currentSession.completed ? 'Session completed' : question.title;
    questionPrompt.textContent = currentSession.completed
      ? 'Review your score, replay the same list, or start a fresh session with a new ID.'
      : question.prompt;
    answerInput.value = response.input || '';
    const isSheetMode = currentSession.format === 'sheet';
    singleView.hidden = isSheetMode;
    sheetView.hidden = !isSheetMode;
    emptyNote.hidden = currentSession !== null;
    controls.forEach((id) => { const node = byId(id); if (node) node.disabled = currentSession.completed; });
    renderVisual(question.visualValue);

    if (isSheetMode) {
      sheetList.replaceChildren();
      currentSession.questions.forEach((entry, index) => {
        const row = document.createElement('div');
        row.className = 'sheet-row';
        const prompt = document.createElement('div');
        prompt.className = 'sheet-prompt';
        prompt.innerHTML = `<strong>${index + 1}.</strong> ${entry.prompt}`;
        const input = document.createElement('input');
        input.className = 'input';
        input.type = 'text';
        input.inputMode = 'numeric';
        input.placeholder = 'Answer';
        input.value = currentSession.responses[index]?.input || '';
        input.addEventListener('input', () => {
          currentSession.responses[index] = {
            ...(currentSession.responses[index] || {}),
            input: input.value,
          };
          persistCurrent();
        });
        row.append(prompt, input);
        sheetList.appendChild(row);
      });
    }

    if (currentSession.timerEnabled && !currentSession.completed) {
      const nextTimerKey = `${currentSession.id}:${currentSession.currentIndex}`;
      if (activeTimerKey !== nextTimerKey) {
        if (timerInterval) window.clearInterval(timerInterval);
        const carriedSeconds = response.seconds || 0;
        questionStartedAt = Date.now() - (carriedSeconds * 1000);
        activeTimerKey = nextTimerKey;
        timerInterval = window.setInterval(() => {
          const seconds = Math.round((Date.now() - questionStartedAt) / 1000);
          timer.textContent = `Timer ${seconds}s`;
        }, 1000);
      }
    } else {
      if (timerInterval) window.clearInterval(timerInterval);
      timerInterval = null;
      questionStartedAt = null;
      activeTimerKey = null;
      if (currentSession.completed) {
        timer.textContent = 'Session complete';
      }
    }

    if (response.verified) {
      feedback.hidden = false;
      if (response.correct && !response.revealedFinal && !response.revealedSteps) {
        feedback.textContent = 'Correct. Keep your hands calm and move to the next question when ready.';
      } else if (response.revealedSteps) {
        feedback.textContent = `Final number: ${question.answer}. The full step method is open below.`;
      } else if (response.revealedFinal) {
        feedback.textContent = `Final number: ${question.answer}. Use this when you only want a quick result check.`;
      } else {
        feedback.textContent = 'Not correct yet. You can try again, reveal the final number, or open the steps.';
      }
    }
    if (response.revealedSteps) {
      stepsPanel.hidden = false;
      stepsPanel.replaceChildren();
      const list = document.createElement('ol');
      question.steps.forEach((step) => {
        const item = document.createElement('li');
        item.textContent = step;
        list.appendChild(item);
      });
      stepsPanel.appendChild(list);
    }
    persistCurrent();
    renderHistory();
  };

  const updateCurrentResponse = (next) => {
    if (!currentSession) return;
    currentSession.responses[currentSession.currentIndex] = {
      ...responseForCurrent(),
      ...next,
    };
    persistCurrent();
  };

  byId('start-session')?.addEventListener('click', () => {
    stopTimer();
      currentSession = createSession({
        type: byId('session-type').value,
        level: byId('session-level').value,
        length: Number(byId('session-length').value),
        checkMode: byId('check-mode').value,
        timerEnabled: byId('timer-mode').value === 'on',
        format: byId('session-format').value,
        questionStyle: byId('question-style').value,
        termCount: byId('term-count').value,
      });
    persistCurrent();
    renderSession();
  });

  byId('resume-latest')?.addEventListener('click', () => {
    stopTimer();
    const latest = readSessions()[0];
    if (!latest) return;
    currentSession = latest;
    renderSession();
  });

  byId('session-level')?.addEventListener('change', (event) => {
    applyPracticeLevelDefaults(event.target.value);
  });

  byId('resume-by-id')?.addEventListener('click', () => {
    stopTimer();
    const requestedId = byId('session-id-input').value.trim();
    if (!requestedId) return;
    const match = readSessions().find((entry) => entry.id === requestedId);
    const feedback = byId('feedback-panel');
    if (!match) {
      feedback.hidden = false;
      feedback.textContent = 'No saved session matched that ID on this device.';
      return;
    }
    currentSession = match;
    renderSession();
  });

  byId('verify-answer')?.addEventListener('click', () => {
    if (!currentSession || currentSession.completed) return;
    const question = currentSession.questions[currentSession.currentIndex];
    const input = byId('answer-input').value.trim();
    const feedback = byId('feedback-panel');
    if (!input) {
      feedback.hidden = false;
      feedback.textContent = 'Write your response first, or choose to reveal the answer or method.';
      return;
    }
    const numericInput = Number(input);
    const correct = input !== '' && !Number.isNaN(numericInput) && numericInput === question.answer;
    updateCurrentResponse({ input, verified: true, correct });
    feedback.hidden = false;
    playTone(correct ? 'success' : 'error');
    feedback.textContent = correct ? 'Correct. Your response matches the answer. You may continue or reveal the method to study it.' : 'Not correct yet. Revise your response, or reveal the answer or the method.';

    if (currentSession.checkMode === 'final' || currentSession.checkMode === 'steps') {
      updateCurrentResponse({ revealedFinal: true });
      feedback.textContent += ` Answer: ${question.answer}.`;
    }
    if (currentSession.checkMode === 'steps') {
      updateCurrentResponse({ revealedSteps: true });
    }
    renderSession();
  });
  byId('answer-input')?.addEventListener('keydown', (event) => {
    if (event.key !== 'Enter') return;
    event.preventDefault();
    byId('verify-answer')?.click();
  });

  byId('reveal-final')?.addEventListener('click', () => {
    if (!currentSession || currentSession.completed) return;
    updateCurrentResponse({ revealedFinal: true, verified: true, correct: responseForCurrent().correct || false, input: byId('answer-input').value.trim() });
    renderSession();
  });

  byId('reveal-steps')?.addEventListener('click', () => {
    if (!currentSession || currentSession.completed) return;
    updateCurrentResponse({ revealedSteps: true, revealedFinal: true, verified: true, correct: responseForCurrent().correct || false, input: byId('answer-input').value.trim() });
    renderSession();
  });

  byId('next-question')?.addEventListener('click', () => {
    if (!currentSession || currentSession.completed) return;
    stopTimer();
    const currentResponse = responseForCurrent();
    const input = byId('answer-input').value.trim();
    updateCurrentResponse({
      input,
      verified: currentResponse.verified || input !== '',
      correct: currentResponse.correct || false,
    });
    if (currentSession.currentIndex < currentSession.questions.length - 1) {
      syncExerciseProgress();
      currentSession.currentIndex += 1;
      renderSession();
      return;
    }
    currentSession.completed = true;
    currentSession.finalScore = computeSessionScore(currentSession);
    syncExerciseProgress();
    persistCurrent();
    renderSession();
    const feedback = byId('feedback-panel');
    feedback.hidden = false;
    feedback.textContent = `Session complete. Final score: ${currentSession.finalScore}/100. You can replay the same list from the history panel or start a fresh session.`;
    renderHistory();
  });

  byId('check-sheet')?.addEventListener('click', () => {
    if (!currentSession || currentSession.completed) return;
    let correctCount = 0;
    currentSession.questions.forEach((question, index) => {
      const input = currentSession.responses[index]?.input?.trim() || '';
      const correct = input !== '' && Number(input) === question.answer;
      currentSession.responses[index] = {
        ...(currentSession.responses[index] || {}),
        input,
        verified: true,
        correct,
      };
      if (correct) correctCount += 1;
    });
    currentSession.finalScore = Math.round((correctCount / currentSession.questions.length) * 100);
    playTone(correctCount === currentSession.questions.length ? 'success' : 'error');
    persistCurrent();
    const feedback = byId('feedback-panel');
    feedback.hidden = false;
    feedback.textContent = `Sheet checked. ${correctCount}/${currentSession.questions.length} correct. Current score ${currentSession.finalScore}/100.`;
    renderSession();
  });

  byId('reveal-sheet-answers')?.addEventListener('click', () => {
    if (!currentSession) return;
    const stepsPanel = byId('steps-panel');
    stepsPanel.hidden = false;
    stepsPanel.replaceChildren();
    const list = document.createElement('ol');
    currentSession.questions.forEach((question) => {
      const item = document.createElement('li');
      item.textContent = `${question.prompt} → ${question.answer}`;
      list.appendChild(item);
    });
    stepsPanel.appendChild(list);
  });

  byId('save-sheet')?.addEventListener('click', () => {
    if (!currentSession) return;
    persistCurrent();
    const feedback = byId('feedback-panel');
    feedback.hidden = false;
    feedback.textContent = 'Sheet progress saved. You can return later and continue where you left off.';
  });

  byId('print-sheet')?.addEventListener('click', () => window.print());

  document.querySelectorAll('[data-preset]').forEach((button) => {
    button.addEventListener('click', () => applyPreset(button.dataset.preset));
  });
  byId('empty-warmup')?.addEventListener('click', () => applyPreset('warmup'));
  document.querySelectorAll('#session-format, #session-type, #session-level, #session-length, #question-style, #term-count, #timer-mode').forEach((node) => {
    node.addEventListener('change', syncPracticeSetupCopy);
  });

  renderHistory();
  syncPracticeSetupCopy();
  applyPracticeLevelDefaults(byId('session-level')?.value || 'L0');
  renderSession();
</script>
