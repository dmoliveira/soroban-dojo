---
import { numberToKanji } from '../lib/japanese';

interface Props {
  value: number;
  label?: string;
  stepValues?: number[];
}

const { value, label = 'Soroban visual', stepValues = [] } = Astro.props;

const toDigits = (input: number) => String(Math.max(0, input)).split('').map((digit) => Number(digit));
const renderValue = (input: number) => toDigits(input).map((digit, index, digits) => ({
  key: `${input}-${index}`,
  digit,
  position: digits.length - index,
  upperActive: digit >= 5,
  lowerActive: digit % 5,
}));

const stepSeries = [value, ...stepValues.filter((entry) => entry !== value)];
---

<section class="soroban-visual panel">
  <div class="section-head">
    <div>
      <p class="eyebrow">Reusable visual engine</p>
      <h2>{label}</h2>
    </div>
    <span class="badge">Value {value} · {numberToKanji(value)}</span>
  </div>
  <div class="soroban-board" aria-label={`${label}: value ${value}`}>
    {renderValue(value).map((rod) => (
      <div class="rod" aria-label={`Digit ${rod.digit}`}>
        <div class:list={["bead", "upper", rod.upperActive && 'active']} />
        <div class="beam" />
        {Array.from({ length: 4 }, (_, index) => (
          <div class:list={["bead", "lower", index < rod.lowerActive && 'active']} />
        ))}
      </div>
    ))}
  </div>
  {stepSeries.length > 1 && (
    <div class="step-series">
      {stepSeries.map((stepValue, index) => (
        <div class="step-card">
          <p class="eyebrow">Step {index + 1}</p>
          <strong>{stepValue}</strong>
        </div>
      ))}
    </div>
  )}
</section>
