---
import { PATHS } from '../lib/constants';
const base = import.meta.env.BASE_URL;
---

<div class="card-grid">
  {PATHS.map((path) => (
    <article class="panel card">
      <p class="eyebrow">Choose your path</p>
      <h2>{path.title}</h2>
      <p>{path.summary}</p>
      <a class="text-link" href={`${base}paths/${path.id}`}>Open path →</a>
    </article>
  ))}
</div>
