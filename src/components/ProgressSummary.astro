---
interface EntrySummary {
  id: string;
  skill: string;
  level: string;
}

interface Props {
  lessons: EntrySummary[];
  exercises: EntrySummary[];
}

const { lessons, exercises } = Astro.props;
---

<section class="panel progress-panel" data-lessons={JSON.stringify(lessons)} data-exercises={JSON.stringify(exercises)}>
  <div class="section-head">
    <div>
      <p class="eyebrow">Progress garden · 歩み</p>
      <h2>Your dojo landscape</h2>
      <p class="muted">A quiet view of your study path: stones for consistency, lanterns for milestones, and blossoms for strong sessions.</p>
    </div>
    <button class="button button-secondary" id="reset-progress">Reset progress</button>
  </div>

  <div class="progress-hero-grid">
    <section class="panel ink-panel">
      <p class="eyebrow">Path of practice</p>
      <h3 id="journey-title">Begin your first stone</h3>
      <p id="journey-copy" class="muted">Small steps, steady hands.</p>
      <div class="garden-strip" id="garden-strip" aria-label="Progress garden"></div>
    </section>

    <section class="panel ink-panel">
      <p class="eyebrow">Dojo rank</p>
      <h3 id="rank-title">Shoshin · Beginner’s mind</h3>
      <p id="rank-copy" class="muted">Start calmly and let repetition shape confidence.</p>
      <div class="ink-meter">
        <div id="ink-meter-fill" class="ink-meter-fill"></div>
      </div>
      <p id="ink-meter-label" class="muted small">0 / 100 path energy</p>
    </section>
  </div>

  <section class="panel ink-panel progress-links-strip">
    <strong>Quick links</strong>
    <div class="button-row button-row-compact">
      <a class="button button-secondary" href="/ai-soroban/lessons">Lessons</a>
      <a class="button button-secondary" href="/ai-soroban/practice">Practice</a>
      <a class="button button-secondary" href="/ai-soroban/worksheets">Worksheets</a>
    </div>
  </section>

  <div class="stats-grid progress-stats-grid">
    <article class="stat-card stat-card-soft"><small>Lessons completed</small><span id="completed-lessons">0</span></article>
    <article class="stat-card stat-card-soft"><small>Exercises attempted</small><span id="attempted-exercises">0</span></article>
    <article class="stat-card stat-card-soft"><small>Items to review</small><span id="review-items">0</span></article>
    <article class="stat-card stat-card-soft"><small>Practice time</small><span id="time-practiced">0m</span></article>
    <article class="stat-card stat-card-soft"><small>Sessions finished</small><span id="finished-sessions">0</span></article>
    <article class="stat-card stat-card-soft"><small>Best score</small><span id="best-score">0</span></article>
  </div>

  <div class="progress-hero-grid">
    <section class="panel ink-panel">
      <p class="eyebrow">Milestones</p>
      <div class="milestone-row" id="milestone-row"></div>
    </section>

    <section class="panel ink-panel">
      <p class="eyebrow">Recent sessions</p>
      <div id="recent-sessions" class="session-list"></div>
    </section>
  </div>

  <section class="panel ink-panel">
    <p class="eyebrow">Recommended next move</p>
    <div class="next-move-grid">
      <div>
        <h3 id="next-move-title">Start your first lesson</h3>
        <p id="next-move-copy" class="muted">Begin with a calm lesson, then move into one short practice session.</p>
      </div>
      <div class="button-row" id="next-move-actions"></div>
    </div>
  </section>

  <section class="panel ink-panel">
    <p class="eyebrow">Skill map</p>
    <h3>Mastery by practice area</h3>
    <div id="skill-map" class="skill-map"></div>
  </section>

  <section class="panel ink-panel">
    <p class="eyebrow">Today’s reflection</p>
    <div class="reflection-grid">
      <div>
        <h3 id="reflection-title">Keep the brush light</h3>
        <p id="reflection-copy" class="muted">Your progress stays in this browser unless you clear it.</p>
      </div>
      <div class="review-chip-row" id="reflection-chips"></div>
    </div>
  </section>
</section>

<script is:inline>
  const root = document.querySelector('.progress-panel');
  const base = '/ai-soroban/';
  const lessonKey = 'soroban-dojo:completed-lessons';
  const exerciseKey = 'soroban-dojo:exercise-states';
  const timerKey = 'soroban-dojo:timer-history';
  const sessionKey = 'soroban-dojo:practice-sessions';
  const lessonMeta = JSON.parse(root?.dataset.lessons || '[]');
  const exerciseMeta = JSON.parse(root?.dataset.exercises || '[]');

  const read = (key, fallback) => {
    try {
      return JSON.parse(localStorage.getItem(key) || JSON.stringify(fallback));
    } catch {
      return fallback;
    }
  };

  const lessonData = read(lessonKey, []);
  const exerciseData = read(exerciseKey, {});
  const timerData = read(timerKey, []);
  const sessionData = read(sessionKey, []);

  const attempted = Object.values(exerciseData).filter(Boolean);
  const reviewItems = Object.values(exerciseData).filter((entry) => entry?.status === 'needs-review');
  const totalSeconds = timerData.reduce((sum, entry) => sum + (entry.seconds || ((entry.minutes || 0) * 60)), 0);
  const totalMinutes = Math.round(totalSeconds / 60);
  const finishedSessions = sessionData.filter((entry) => entry?.completed);
  const bestScore = finishedSessions.reduce((best, entry) => Math.max(best, entry.finalScore || 0), 0);
  const journeyEnergy = Math.min(100, lessonData.length * 10 + attempted.length * 2 + finishedSessions.length * 6 + Math.floor(totalMinutes / 5));

  const rankBands = [
    { max: 20, title: 'Shoshin · Beginner’s mind', copy: 'Begin calmly and let each repetition become a brush stroke.' },
    { max: 40, title: 'Kaizen · Steady growth', copy: 'Your path is forming through small, honest steps.' },
    { max: 65, title: 'Rei · Disciplined rhythm', copy: 'You are building respectful consistency in the dojo.' },
    { max: 85, title: 'Ma · Calm space', copy: 'Your work shows control, spacing, and steadier confidence.' },
    { max: 100, title: 'Takumi · Refined hands', copy: 'Your sessions now carry a stronger sense of craft.' },
  ];
  const currentRank = rankBands.find((entry) => journeyEnergy <= entry.max) || rankBands[rankBands.length - 1];

  const gardenStrip = document.getElementById('garden-strip');
  const milestoneRow = document.getElementById('milestone-row');
  const recentSessions = document.getElementById('recent-sessions');
  const reflectionChips = document.getElementById('reflection-chips');
  const skillMap = document.getElementById('skill-map');
  const nextMoveActions = document.getElementById('next-move-actions');

  document.getElementById('completed-lessons').textContent = String(lessonData.length);
  document.getElementById('attempted-exercises').textContent = String(attempted.length);
  document.getElementById('review-items').textContent = String(reviewItems.length);
  document.getElementById('time-practiced').textContent = `${totalMinutes}m`;
  document.getElementById('finished-sessions').textContent = String(finishedSessions.length);
  document.getElementById('best-score').textContent = String(bestScore);

  document.getElementById('rank-title').textContent = currentRank.title;
  document.getElementById('rank-copy').textContent = currentRank.copy;
  document.getElementById('ink-meter-fill').style.width = `${journeyEnergy}%`;
  document.getElementById('ink-meter-label').textContent = `${journeyEnergy} / 100 path energy`;

  const journeyTitle = lessonData.length ? `You have placed ${lessonData.length} stones on your path` : 'Begin your first stone';
  const journeyCopy = finishedSessions.length
    ? `You have completed ${finishedSessions.length} formal sessions and your best score is ${bestScore}/100.`
    : 'Small steps, steady hands.';
  document.getElementById('journey-title').textContent = journeyTitle;
  document.getElementById('journey-copy').textContent = journeyCopy;

  const setNextMove = (title, copy, actions) => {
    document.getElementById('next-move-title').textContent = title;
    document.getElementById('next-move-copy').textContent = copy;
    nextMoveActions.replaceChildren();
    actions.forEach(({ href, label, secondary }) => {
      const link = document.createElement('a');
      link.href = href;
      link.className = secondary ? 'button button-secondary' : 'button';
      link.textContent = label;
      nextMoveActions.appendChild(link);
    });
  };

  if (!lessonData.length) {
    setNextMove('Start your first lesson', 'Begin with a calm lesson, then move into one short practice session.', [
      { href: '/ai-soroban/start-here', label: 'Start here' },
      { href: '/ai-soroban/lessons', label: 'Browse lessons', secondary: true },
    ]);
  } else if (reviewItems.length) {
    setNextMove('Review weak areas next', 'You have items marked for review. Repairing them now is the best way to steady your progress.', [
      { href: '/ai-soroban/practice', label: 'Open practice' },
      { href: '/ai-soroban/worksheets', label: 'Open worksheet', secondary: true },
    ]);
  } else if (!finishedSessions.length) {
    setNextMove('Complete a full session', 'You have started learning; now complete one focused session to build rhythm.', [
      { href: '/ai-soroban/practice', label: 'Start practice' },
      { href: '/ai-soroban/worksheets', label: 'Generate worksheet', secondary: true },
    ]);
  } else {
    setNextMove('Advance with stronger drills', 'Your recent progress is steady. Push forward with a worksheet or a fresh practice session.', [
      { href: '/ai-soroban/worksheets', label: 'Open worksheet' },
      { href: '/ai-soroban/practice', label: 'New practice session', secondary: true },
    ]);
  }

  const gardenPieces = [
    ...Array.from({ length: Math.min(lessonData.length, 6) }, () => 'stone'),
    ...Array.from({ length: Math.min(finishedSessions.length, 4) }, () => 'lantern'),
    ...Array.from({ length: bestScore >= 70 ? 2 : bestScore >= 40 ? 1 : 0 }, () => 'blossom'),
  ];
  if (!gardenPieces.length) gardenPieces.push('stone');
  gardenPieces.forEach((piece) => {
    const node = document.createElement('div');
    node.className = `garden-piece ${piece}`;
    gardenStrip.appendChild(node);
  });

  const milestones = [
    { label: 'First lesson', active: lessonData.length >= 1 },
    { label: 'Five lessons', active: lessonData.length >= 5 },
    { label: 'First session', active: finishedSessions.length >= 1 },
    { label: 'Strong score', active: bestScore >= 70 },
    { label: 'Long practice', active: totalMinutes >= 30 },
  ];
  milestones.forEach((milestone) => {
    const card = document.createElement('div');
    card.className = `milestone-chip ${milestone.active ? 'active' : ''}`;
    card.textContent = milestone.label;
    milestoneRow.appendChild(card);
  });

  if (sessionData.length) {
    sessionData.slice(0, 4).forEach((entry) => {
      const card = document.createElement('article');
      card.className = 'session-card';
      const title = document.createElement('strong');
      title.textContent = `${entry.type} · ${entry.level}`;
      const meta = document.createElement('p');
      meta.className = 'muted';
      meta.textContent = entry.completed ? `Final score ${entry.finalScore}/100` : `Progress ${entry.currentIndex}/${entry.questions.length}`;
      card.append(title, meta);
      recentSessions.appendChild(card);
    });
  } else {
    recentSessions.innerHTML = '<p class="muted">Your recent sessions will appear here after your first full practice.</p>';
  }

  const reflectionItems = [
    lessonData.length ? `${lessonData.length} lesson stones` : 'Start one lesson',
    reviewItems.length ? `${reviewItems.length} items ready for repair` : 'No urgent review items',
    finishedSessions.length ? `${finishedSessions.length} finished sessions` : 'Finish your first session',
    bestScore ? `Best score ${bestScore}/100` : 'Aim for one strong score',
  ];
  reflectionItems.forEach((text) => {
    const chip = document.createElement('span');
    chip.className = 'review-chip';
    chip.textContent = text;
    reflectionChips.appendChild(chip);
  });

  const reflectionTitle = reviewItems.length ? 'Kintsugi moment' : 'Keep the brush light';
  const reflectionCopy = reviewItems.length
    ? 'A few places need repair. That is part of learning, not a setback.'
    : 'Your progress stays in this browser unless you clear it.';
  document.getElementById('reflection-title').textContent = reflectionTitle;
  document.getElementById('reflection-copy').textContent = reflectionCopy;

  const skillBuckets = ['abacus-orientation', 'number-reading', 'place-value', 'number-setting', 'addition', 'subtraction', 'complements', 'mixed-operations', 'multiplication', 'division'];
  const labelize = (value) => value.replace(/-/g, ' ');
  skillBuckets.forEach((skill) => {
    const lessonHits = lessonMeta.filter((entry) => entry.skill === skill && lessonData.includes(entry.id)).length;
    const exerciseHits = exerciseMeta.filter((entry) => entry.skill === skill && exerciseData[entry.id]).length;
    const reviewHits = exerciseMeta.filter((entry) => entry.skill === skill && exerciseData[entry.id]?.status === 'needs-review').length;
    const energy = Math.min(100, lessonHits * 30 + exerciseHits * 15 - reviewHits * 10);
    const row = document.createElement('article');
    row.className = 'skill-row';
    const name = document.createElement('div');
    name.className = 'skill-label';
    name.innerHTML = `<strong>${labelize(skill)}</strong><small>${lessonHits} lessons · ${exerciseHits} exercises</small>`;
    const meter = document.createElement('div');
    meter.className = 'skill-meter';
    const fill = document.createElement('div');
    fill.className = 'skill-meter-fill';
    fill.style.width = `${Math.max(8, energy)}%`;
    meter.appendChild(fill);
    const meta = document.createElement('span');
    meta.className = 'muted small';
    meta.textContent = reviewHits ? `${reviewHits} review item(s)` : `${energy}% steady`; 
    const actions = document.createElement('div');
    actions.className = 'skill-actions';
    const practiceLink = document.createElement('a');
    practiceLink.href = `${base}practice`;
    practiceLink.className = 'text-link';
    practiceLink.textContent = 'Practice';
    const worksheetLink = document.createElement('a');
    worksheetLink.href = `${base}worksheets`;
    worksheetLink.className = 'text-link';
    worksheetLink.textContent = 'Worksheet';
    actions.append(practiceLink, worksheetLink);
    row.append(name, meter, meta, actions);
    skillMap.appendChild(row);
  });

  document.getElementById('reset-progress')?.addEventListener('click', () => {
    localStorage.removeItem(lessonKey);
    localStorage.removeItem(exerciseKey);
    localStorage.removeItem(timerKey);
    localStorage.removeItem(sessionKey);
    window.location.reload();
  });
</script>
