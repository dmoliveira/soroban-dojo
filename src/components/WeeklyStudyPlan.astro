---
interface LessonEntry {
  id: string;
  title: string;
  slug: string;
  skill: string;
  level: string;
}

interface ExerciseEntry {
  id: string;
  title: string;
  slug: string;
  skill: string;
  level: string;
}

interface Props {
  lessons: LessonEntry[];
  exercises: ExerciseEntry[];
}

const { lessons, exercises } = Astro.props;
---

<section class="panel weekly-plan-panel" data-lessons={JSON.stringify(lessons)} data-exercises={JSON.stringify(exercises)}>
  <div class="section-head">
    <div>
      <p class="eyebrow">Weekly plan</p>
      <h2>Your next 7 days</h2>
      <p class="muted">A practical route through one lesson, one exercise, and one worksheet at a time, based on your recent weak areas.</p>
    </div>
  </div>

  <div class="subtle-panel weekly-plan-summary">
    <strong id="weekly-plan-title">Calm weekly path</strong>
    <p id="weekly-plan-copy" class="muted">The plan will adapt as you complete lessons and mark review items.</p>
  </div>

  <div class="weekly-plan-grid" id="weekly-plan-grid"></div>
</section>

<script is:inline>
  const root = document.querySelector('.weekly-plan-panel');
  const lessons = JSON.parse(root?.dataset.lessons || '[]');
  const exercises = JSON.parse(root?.dataset.exercises || '[]');
  const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
  const exerciseKey = 'soroban-dojo:exercise-states';
  const lessonKey = 'soroban-dojo:completed-lessons';
  const weeklyPlanKey = 'soroban-dojo:weekly-study-plan';

  const read = (key, fallback) => {
    try {
      return JSON.parse(localStorage.getItem(key) || JSON.stringify(fallback));
    } catch {
      return fallback;
    }
  };

  const completedLessons = read(lessonKey, []);
  const exerciseStates = read(exerciseKey, {});
  const weakAreas = Object.values(exerciseStates).reduce((acc, entry) => {
    if (entry?.status !== 'needs-review') return acc;
    const skill = entry.skill || '';
    if (skill === 'division') acc.division += 1;
    else if (skill === 'multiplication') acc.multiplication += 1;
    else if (skill === 'complements') acc.complements += 1;
    else if (skill === 'anzan' || skill === 'mastery') acc.mental += 1;
    else acc.arithmetic += 1;
    return acc;
  }, { arithmetic: 0, complements: 0, multiplication: 0, division: 0, mental: 0 });

  const target = ['mental', 'division', 'multiplication', 'complements', 'arithmetic']
    .sort((a, b) => weakAreas[b] - weakAreas[a])[0];

  const planByTarget = {
    arithmetic: {
      title: 'Arithmetic rhythm week',
      copy: 'Keep the total readable through mixed additions and subtractions before adding more speed.',
      lesson: 'lesson-l3-001',
      exercise: 'exercise-l3-001',
      worksheet: `${base}worksheets?preset=mixed-fluency&submode=arithmetic-rhythm`,
    },
    complements: {
      title: 'Complements repair week',
      copy: 'Return to five and ten complements until blocked moves become immediate again.',
      lesson: 'lesson-l2-002',
      exercise: 'exercise-l2-003',
      worksheet: `${base}worksheets?preset=complements&submode=complement-balance`,
    },
    multiplication: {
      title: 'Multiplication structure week',
      copy: 'Focus on place shifts and repeated table families before using broad mixed multiplication drills.',
      lesson: 'lesson-l4-005',
      exercise: 'exercise-l4-005',
      worksheet: `${base}worksheets?preset=multiplication-focus&submode=place-shifts`,
    },
    division: {
      title: 'Division quotient week',
      copy: 'Practice exact quotient building and fact-family verification before harder mixed division sheets.',
      lesson: 'lesson-l4-006',
      exercise: 'exercise-l4-007',
      worksheet: `${base}worksheets?preset=division-focus&submode=quotient-building`,
    },
    mental: {
      title: 'Mental stability week',
      copy: 'Use short anzan sequences and rhythm checks before increasing speed or complexity.',
      lesson: 'lesson-l5-001',
      exercise: 'exercise-l5-001',
      worksheet: `${base}worksheets?preset=anzan-focus&submode=anzan-recall`,
    },
  };

  const plan = planByTarget[target];
  const lesson = lessons.find((entry) => entry.id === plan.lesson) || lessons[0];
  const exercise = exercises.find((entry) => entry.id === plan.exercise) || exercises[0];

  const readPlanState = () => {
    try {
      return JSON.parse(localStorage.getItem(weeklyPlanKey) || '{}');
    } catch {
      return {};
    }
  };

  const writePlanState = (state) => localStorage.setItem(weeklyPlanKey, JSON.stringify(state));

  const currentPlanState = readPlanState();
  const normalizedPlanState = currentPlanState.target === target
    ? currentPlanState
    : {
        target,
        title: plan.title,
        lesson: { id: plan.lesson, done: false },
        exercise: { id: plan.exercise, done: false },
        worksheet: { href: plan.worksheet, done: false },
      };
  writePlanState(normalizedPlanState);

  document.getElementById('weekly-plan-title').textContent = plan.title;
  document.getElementById('weekly-plan-copy').textContent = plan.copy;

  const cards = [
    {
      eyebrow: 'Day 1-2',
      key: 'lesson',
      title: lesson?.title || 'Lesson review',
      copy: completedLessons.includes(lesson?.id) ? 'You already completed this lesson once. Re-read it quickly, then move straight into the exercise.' : 'Start with the concept explanation and worked example before drilling.',
      href: `${base}lessons/${lesson?.slug}`,
      label: 'Open lesson',
    },
    {
      eyebrow: 'Day 3-4',
      key: 'exercise',
      title: exercise?.title || 'Exercise review',
      copy: 'Attempt the exercise first, then use the hint or reveal only if the structure is still unclear.',
      href: `${base}exercises/${exercise?.slug}`,
      label: 'Open exercise',
    },
    {
      eyebrow: 'Day 5-7',
      key: 'worksheet',
      title: 'Focused worksheet set',
      copy: 'Use a printable or on-screen sheet that matches the same weak area and submode.',
      href: plan.worksheet,
      label: 'Open worksheet',
    },
  ];

  const grid = document.getElementById('weekly-plan-grid');
  cards.forEach((card) => {
    const article = document.createElement('article');
    article.className = 'subtle-panel weekly-plan-card';
    const done = normalizedPlanState[card.key]?.done;
    article.innerHTML = `<p class="eyebrow">${card.eyebrow}</p><h3>${card.title}</h3><p class="muted">${card.copy}</p><div class="button-row button-row-compact"><a class="button button-secondary" href="${card.href}">${card.label}</a><button class="button button-secondary weekly-plan-toggle" type="button" data-step="${card.key}">${done ? 'Mark pending' : 'Mark done'}</button></div><p class="muted small weekly-plan-status">${done ? 'Completed for this week.' : 'Still active in this week\'s plan.'}</p>`;
    grid.appendChild(article);
  });

  grid.querySelectorAll('.weekly-plan-toggle').forEach((button) => {
    button.addEventListener('click', () => {
      const state = readPlanState();
      const step = button.dataset.step;
      if (!step) return;
      state[step] = { ...(state[step] || {}), done: !state[step]?.done };
      writePlanState(state);
      const status = button.closest('.weekly-plan-card')?.querySelector('.weekly-plan-status');
      const done = state[step]?.done;
      button.textContent = done ? 'Mark pending' : 'Mark done';
      if (status) status.textContent = done ? 'Completed for this week.' : 'Still active in this week\'s plan.';
    });
  });
</script>
