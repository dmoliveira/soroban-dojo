<section class="panel certificate-summary-panel">
  <div class="section-head">
    <div>
      <p class="eyebrow">Certificates</p>
      <h2>Earned printable milestones</h2>
      <p class="muted">Each cleared boss round can become a certificate entry you can print or share as text.</p>
    </div>
  </div>
  <div id="certificate-summary-list" class="session-list"></div>
</section>

<script is:inline>
  const key = 'soroban-dojo:boss-certificates';
  const mount = document.getElementById('certificate-summary-list');
  const read = () => { try { return JSON.parse(localStorage.getItem(key) || '{}'); } catch { return {}; } };
  const certificates = read();
  const levels = ['L0', 'L1', 'L2', 'L3', 'L4', 'L5'];

  if (!levels.some((level) => certificates[level])) {
    const note = document.createElement('p');
    note.className = 'muted';
    note.textContent = 'No certificates earned yet. Finish one boss round to start your certificate archive.';
    mount.appendChild(note);
  } else {
    levels.forEach((level) => {
      const entry = certificates[level];
      if (!entry) return;
      const card = document.createElement('article');
      card.className = 'session-card';
      card.innerHTML = `<strong>${level} certificate</strong><div class="meta-row"><span>${entry.name}</span><span>${entry.date}</span></div><p class="muted small">${entry.name} cleared the ${level} boss round.</p>`;
      mount.appendChild(card);
    });
  }
</script>
