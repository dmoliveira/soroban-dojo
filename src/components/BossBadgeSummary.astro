<section class="panel boss-badge-panel">
  <div class="section-head">
    <div>
      <p class="eyebrow">Boss badges</p>
      <h2>Earned level milestones</h2>
      <p class="muted">Complete boss rounds to earn visible badges that mark each cleared level.</p>
    </div>
  </div>
  <div id="boss-badge-strip" class="milestone-row"></div>
  <div id="boss-badge-copy" class="empty-state-card muted small">
    <div class="empty-state-head"><span class="empty-state-mark">✦</span><strong>No badges yet</strong></div>
    <p>Clear one boss round to begin your earned badge row.</p>
  </div>
</section>

<script is:inline>
  const key = 'soroban-dojo:boss-rounds';
  const strip = document.getElementById('boss-badge-strip');
  const copy = document.getElementById('boss-badge-copy');
  const levels = ['L0', 'L1', 'L2', 'L3', 'L4', 'L5'];
  const read = () => { try { return JSON.parse(localStorage.getItem(key) || '{}'); } catch { return {}; } };
  const state = read();
  let earned = 0;
  levels.forEach((level) => {
    const chip = document.createElement('div');
    const done = !!state[level];
    if (done) earned += 1;
    chip.className = `milestone-chip ${done ? 'active' : ''}`;
    chip.textContent = done ? `${level} badge` : `${level} available later`;
    strip.appendChild(chip);
  });
  if (earned) {
    copy.className = 'reward-state-card muted small';
    copy.innerHTML = `<div class="reward-state-head"><span class="reward-state-mark">✓</span><strong>${earned} badge${earned === 1 ? '' : 's'} earned</strong></div><p>Keep clearing levels to fill the full row.</p>`;
  } else {
    copy.className = 'empty-state-card muted small';
    copy.innerHTML = '<div class="empty-state-head"><span class="empty-state-mark">✦</span><strong>No badges yet</strong></div><p>Clear one boss round to begin your earned badge row.</p>';
  }
</script>
