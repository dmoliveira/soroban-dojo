---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SorobanVisualizer from '../../components/SorobanVisualizer.astro';
import { numberToKanji } from '../../lib/japanese';

export async function getStaticPaths() {
  const exercises = await getCollection('exercises');
  return exercises.map((exercise) => ({ params: { slug: exercise.slug }, props: { exercise } }));
}

const { exercise } = Astro.props;
const { Content } = await render(exercise);
---

<BaseLayout title={`${exercise.data.title} | Soroban Dojo`}>
  <article class="panel content-prose">
    <p class="eyebrow">Exercise · {exercise.data.level}</p>
    <h1>{exercise.data.title}</h1>
    <div class="meta-row">
      <span>{exercise.data.skill}</span>
      <span>{exercise.data.type}</span>
      <span>{exercise.data.estimatedMinutes} min</span>
      {exercise.data.visualValue !== undefined && <span>数 {numberToKanji(exercise.data.visualValue)}</span>}
    </div>
    <p><strong>Practice rule:</strong> try this before opening the hint or answer.</p>
    {exercise.data.visualValue !== undefined && (
      <SorobanVisualizer value={exercise.data.visualValue} stepValues={exercise.data.stepValues} label={`Visual support for ${exercise.data.title}`} />
    )}
    <Content />

    <section class="panel exercise-interaction-panel">
      <p class="eyebrow">Attempt first</p>
      <div class="question-flow-note">
        <span class="review-chip">1. Solve first</span>
        <span class="review-chip">2. Write your response</span>
        <span class="review-chip">3. Verify or reveal</span>
      </div>
      <label class="stack-sm answer-stack">
        <span>Your response</span>
        <input id="exercise-response" class="input" type="text" inputmode="numeric" placeholder="Write your response before checking" />
      </label>
      <div class="button-row button-row-compact">
        <button class="button" id="verify-exercise">Verify response</button>
        <button class="button button-secondary" id="hint-exercise">Need a hint?</button>
        <button class="button button-secondary" id="reveal-answer">Reveal answer</button>
        <button class="button button-secondary" id="reveal-method">Reveal method</button>
      </div>
      <div class="exercise-state-strip">
        <div class="exercise-state-card"><span id="exercise-state-response">—</span><small>Response</small></div>
        <div class="exercise-state-card"><span id="exercise-state-status">Not checked</span><small>Status</small></div>
      </div>
      <div id="exercise-feedback" class="reveal-panel" hidden role="status" aria-live="polite"></div>
      <div id="exercise-method" class="reveal-panel" hidden></div>
    </section>
  </article>

  <script is:inline define:vars={{ answer: exercise.data.answer, hint: exercise.data.hint, explanation: exercise.data.explanation }}>
    const responseInput = document.getElementById('exercise-response');
    const feedback = document.getElementById('exercise-feedback');
    const method = document.getElementById('exercise-method');
    const responseState = document.getElementById('exercise-state-response');
    const statusState = document.getElementById('exercise-state-status');

    const normalizeNumber = (value) => {
      const parsed = Number(value.trim());
      return Number.isNaN(parsed) ? null : parsed;
    };

    document.getElementById('verify-exercise')?.addEventListener('click', () => {
      const value = responseInput.value.trim();
      if (!value) {
        feedback.hidden = false;
        feedback.textContent = 'Write your response first, or choose to reveal the answer or method.';
        responseState.textContent = 'Empty';
        statusState.textContent = 'Waiting';
        return;
      }
      const expected = normalizeNumber(answer);
      const actual = normalizeNumber(value);
      const correct = expected !== null && actual === expected;
      feedback.hidden = false;
      feedback.textContent = correct ? 'Correct. Your response matches the answer.' : 'Not correct yet. Revise your response, ask for a hint, or reveal the answer.';
      responseState.textContent = value;
      statusState.textContent = correct ? 'Correct' : 'Try again';
    });

    document.getElementById('hint-exercise')?.addEventListener('click', () => {
      feedback.hidden = false;
      feedback.textContent = `Hint: ${hint}`;
      statusState.textContent = 'Hint shown';
    });

    document.getElementById('reveal-answer')?.addEventListener('click', () => {
      feedback.hidden = false;
      feedback.textContent = `Answer: ${answer}`;
      statusState.textContent = 'Answer shown';
    });

    document.getElementById('reveal-method')?.addEventListener('click', () => {
      method.hidden = false;
      method.textContent = explanation;
      statusState.textContent = 'Method shown';
    });
  </script>
</BaseLayout>
