---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const exercises = (await getCollection('exercises')).sort((a, b) => a.data.id.localeCompare(b.data.id));
const levelOrder = ['L0', 'L1', 'L2', 'L3', 'L4', 'L5'];
const groupedExercises = levelOrder.map((level) => ({ level, items: exercises.filter((entry) => entry.data.level === level) })).filter((group) => group.items.length);
const specialFormats = exercises.filter((entry) => ['reading-race', 'matching', 'error-diagnosis'].includes(entry.data.type));
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Exercises | Soroban Dojo">
  <section class="panel">
    <p class="eyebrow">Exercise library</p>
    <h1>Attempt first. Then compare.</h1>
    <p class="muted">Use these like a skill ladder: concept checks first, then rhythm drills, then challenge-style review inside practice and worksheets.</p>
    <div class="content-prose">
      {groupedExercises.map((group) => (
        <section>
          <h2>{group.level}</h2>
          <ul class="list-clean">
            {group.items.map((exercise) => (
              <li>
                <strong>{exercise.data.title}</strong>
                <div class="meta-row">
                  <span>{exercise.data.level}</span>
                  <span>{exercise.data.skill}</span>
                  <span>Difficulty {exercise.data.difficulty}</span>
                </div>
                <p>{exercise.data.explanation}</p>
                <a class="text-link" href={`${base}exercises/${exercise.slug}`}>Open exercise →</a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </section>

  <section class="panel">
    <p class="eyebrow">Special formats</p>
    <h2>Playful exercise types</h2>
    <ul class="list-clean">
      {specialFormats.map((exercise) => (
        <li>
          <strong>{exercise.data.title}</strong>
          <div class="meta-row">
            <span>{exercise.data.level}</span>
            <span>{exercise.data.type}</span>
            <span>{exercise.data.skill}</span>
          </div>
          <p>{exercise.data.explanation}</p>
          <a class="text-link" href={`${base}exercises/${exercise.slug}`}>Open special exercise →</a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
