---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const exercises = (await getCollection('exercises')).sort((a, b) => a.data.id.localeCompare(b.data.id));
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Exercises | Soroban Dojo">
  <section class="panel">
    <p class="eyebrow">Exercise library</p>
    <h1>Attempt first. Then compare.</h1>
    <ul class="list-clean">
      {exercises.map((exercise) => (
        <li>
          <strong>{exercise.data.title}</strong>
          <div class="meta-row">
            <span>{exercise.data.level}</span>
            <span>{exercise.data.skill}</span>
            <span>Difficulty {exercise.data.difficulty}</span>
          </div>
          <p>{exercise.data.explanation}</p>
          <a class="text-link" href={`${base}exercises/${exercise.slug}`}>Open exercise →</a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
