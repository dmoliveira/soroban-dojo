---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Adult Path | Soroban Dojo">
  <section class="panel content-prose">
    <p class="eyebrow">Adult path</p>
    <h1>Structured self-study with practical rhythm</h1>
    <p>This path keeps explanations direct, practice disciplined, and progress easy to continue across short study sessions.</p>
    <ul>
      <li>10–20 minute sessions</li>
      <li>Clear objectives and prerequisites</li>
      <li>Review recommendations for weak points</li>
    </ul>
    <div class="hero-actions">
      <a class="button" href={`${base}levels/l0`}>Start at Foundations</a>
      <a class="button button-secondary" href={`${base}practice`}>Go to practice</a>
    </div>
  </section>
</BaseLayout>
