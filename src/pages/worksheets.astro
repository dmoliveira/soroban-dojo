---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Soroban Worksheets | Soroban Dojo">
  <section class="panel content-prose no-print">
    <p class="eyebrow">Soroban sheets · 印刷</p>
    <h1>Ledger-style drill sheets</h1>
    <p>Choose a fixed curriculum sheet or generate a denser practice ledger by level, operation family, and digit band. Blank responses are skipped; partial score uses only answered drills.</p>

    <div class="ledger-controls worksheet-controls-shell">
      <div class="worksheet-controls-grid worksheet-controls-grid-main">
      <label class="stack-sm">
        <span>Sheet mode</span>
        <select id="worksheet-mode" class="select">
          <option value="fixed">Fixed sheet</option>
          <option value="dynamic">Dynamic ledger</option>
          <option value="adaptive">Adaptive ledger</option>
        </select>
      </label>
      <label class="stack-sm">
        <span>Level</span>
        <select id="worksheet-level" class="select">
          <option value="L0">L0 Foundations</option>
          <option value="L1">L1 Beginner</option>
          <option value="L2">L2 Complements</option>
          <option value="L3">L3 Mixed</option>
          <option value="L4">L4 Multiplication & division</option>
          <option value="L5">L5 Mastery</option>
        </select>
      </label>
      <fieldset class="stack-sm worksheet-operation-group">
        <legend>Operation family</legend>
        <div class="operation-chip-grid">
          <label class="operation-chip"><input type="checkbox" name="worksheet-family" value="addition" checked />Addition</label>
          <label class="operation-chip"><input type="checkbox" name="worksheet-family" value="subtraction" />Subtraction</label>
          <label class="operation-chip"><input type="checkbox" name="worksheet-family" value="mixed" />Mixed</label>
          <label class="operation-chip"><input type="checkbox" name="worksheet-family" value="sequence" />Sequence</label>
          <label class="operation-chip"><input type="checkbox" name="worksheet-family" value="multiplication" />Multiplication</label>
          <label class="operation-chip"><input type="checkbox" name="worksheet-family" value="division" />Division</label>
          <label class="operation-chip"><input type="checkbox" name="worksheet-family" value="anzan" />Anzan / mental</label>
        </div>
      </fieldset>
      <label class="stack-sm">
        <span>Digit band</span>
        <select id="worksheet-band" class="select">
          <option value="1">1 digit</option>
          <option value="2">2 digits</option>
          <option value="3">3 digits</option>
          <option value="4">4 digits</option>
          <option value="1-2">1–2 digits</option>
          <option value="2-3" selected>2–3 digits</option>
          <option value="3-4">3–4 digits</option>
          <option value="4-6">4–6 digits</option>
        </select>
      </label>
      </div>
      <details class="worksheet-advanced-block">
        <summary>Advanced options</summary>
        <div class="worksheet-controls-grid worksheet-controls-grid-advanced">
          <label class="stack-sm">
            <span>Sheet type</span>
            <select id="worksheet-style" class="select">
              <option value="practice">Practice</option>
              <option value="speed">Speed</option>
              <option value="review">Review</option>
              <option value="exam">Exam</option>
              <option value="teacher">Teacher key</option>
            </select>
          </label>
          <label class="stack-sm">
            <span>Orientation</span>
            <select id="worksheet-orientation" class="select">
              <option value="ledger" selected>Ledger rows</option>
              <option value="vertical">Vertical columns</option>
            </select>
          </label>
          <label class="stack-sm">
            <span>Drills</span>
            <select id="worksheet-count" class="select">
              <option value="20">20</option>
              <option value="40" selected>40</option>
              <option value="60">60</option>
              <option value="100">100</option>
            </select>
          </label>
          <label class="stack-sm">
            <span>Stopwatch</span>
            <select id="worksheet-timer-mode" class="select">
              <option value="off">Off</option>
              <option value="on">On</option>
            </select>
          </label>
        </div>
      </details>
    </div>

    <div class="button-row worksheet-action-row">
      <button class="button" id="generate-worksheet">Generate ledger</button>
      <button class="button button-secondary" id="check-worksheet">Check answered</button>
      <button class="button button-secondary" id="reveal-worksheet">Reveal answers</button>
      <button class="button button-secondary" id="teacher-key">Teacher key</button>
      <button class="button button-secondary" id="worksheet-timer-toggle">Start timer</button>
      <button class="button button-secondary" onclick="window.print()">Print sheet</button>
      <a class="button button-secondary" href={`${base}practice`}>Return to practice</a>
    </div>

    <div class="worksheet-scorebar subtle-panel" id="worksheet-scorebar">
      <strong>Score</strong>
      <span id="worksheet-score-copy" class="muted">No answers checked yet.</span>
    </div>
    <div class="worksheet-score-grid">
      <article class="stat-card stat-card-soft"><span id="worksheet-answered">0</span><small>Answered</small></article>
      <article class="stat-card stat-card-soft"><span id="worksheet-correct">0</span><small>Correct</small></article>
      <article class="stat-card stat-card-soft"><span id="worksheet-accuracy">0%</span><small>Accuracy</small></article>
      <article class="stat-card stat-card-soft"><span id="worksheet-completion">0%</span><small>Completion</small></article>
      <article class="stat-card stat-card-soft"><span id="worksheet-time">0s</span><small>Time</small></article>
    </div>
    <div id="adaptive-note" class="subtle-panel no-print" hidden>
      <strong>Adaptive recommendation</strong>
      <p id="adaptive-note-copy" class="muted">This sheet is tuned to your recent weak areas stored in local progress.</p>
    </div>
    <div id="teacher-note" class="subtle-panel no-print" hidden>
      <strong>Teacher view</strong>
      <p class="muted">Use this mode to print answer keys or review drills aloud. Answers remain visible while blank student rows are left untouched.</p>
    </div>
  </section>

  <section class="worksheet-board">
    <article class="panel worksheet-panel ledger-panel">
      <div class="section-head">
        <div>
          <p class="eyebrow">Drill ledger</p>
          <h2 id="worksheet-title">Standard Soroban drill set</h2>
        </div>
        <span class="badge" id="worksheet-count-badge">40 drills</span>
      </div>
      <div id="worksheet-ledger-head" class="ledger-head ledger-row">
        <span>No.</span>
        <span>Drill</span>
        <span>Response</span>
        <span>Result</span>
        <span>Actions</span>
      </div>
      <div id="worksheet-table" class="worksheet-table ledger-table"></div>
    </article>
  </section>

  <script is:inline>
    const fixedBanks = {
      L0: {
        addition: ['1 + 2','2 + 1','2 + 2','3 + 1','4 + 1','1 + 3','2 + 3','3 + 2','4 + 2','5 + 1'],
        subtraction: ['4 - 1','5 - 2','6 - 1','7 - 3','8 - 2','6 - 2','7 - 1','8 - 4','9 - 3','9 - 2'],
      },
      L1: {
        addition: ['12 + 5','24 + 7','31 + 4','18 + 6','42 + 13','25 + 11','33 + 14','47 + 21','51 + 8','62 + 17'],
        subtraction: ['24 - 7','31 - 4','18 - 6','42 - 13','55 - 12','63 - 21','80 - 15','74 - 32','91 - 18','64 - 9'],
      },
      L2: {
        mixed: ['24 + 7','31 - 4','18 + 5','42 - 11','25 + 6','36 - 12','27 + 8','44 - 9','52 - 18','19 + 14'],
        sequence: ['12 + 5 - 3','24 - 7 + 6','18 + 5 + 2','42 - 11 + 4','25 + 6 - 4','36 - 12 + 5','27 + 8 - 6','44 - 9 + 3','52 - 18 + 7','19 + 14 - 9'],
      },
      L3: {
        mixed: ['124 + 37','231 - 44','318 + 56','442 - 111','205 + 16','360 - 124','274 + 88','440 - 95','520 - 184','193 + 147'],
        sequence: ['124 + 37 - 15','231 - 44 + 18','318 + 56 - 21','442 - 111 + 24','205 + 16 + 19','360 - 124 + 37','274 + 88 - 46','440 - 95 + 18','520 - 184 + 29','193 + 147 - 58'],
      },
      L4: {
        multiplication: ['3 × 4','4 × 3','12 × 2','5 × 12','13 × 5','6 × 12','14 × 4','3 × 16','17 × 2','15 × 3'],
        division: ['12 ÷ 3','12 ÷ 4','40 ÷ 5','45 ÷ 5','36 ÷ 6','48 ÷ 6','56 ÷ 7','63 ÷ 9','72 ÷ 8','81 ÷ 9'],
      },
      L5: {
        mixed: ['1245 + 378','2318 - 444','3186 + 567','4420 - 1114','2057 + 168','3604 - 1248','2745 + 889','4400 - 955','5208 - 1842','1937 + 1476'],
        anzan: ['18 + 7 + 5','24 - 6 + 8','37 + 14 - 9','45 - 8 + 6','63 + 12 - 15','72 - 18 + 9','84 + 15 - 11','96 - 24 + 8','128 + 37 - 15','205 - 18 + 27'],
      },
    };

    const levelBands = {
      L0: '1',
      L1: '2',
      L2: '2-3',
      L3: '3-4',
      L4: '2-4',
      L5: '4-6',
    };

    const byId = (id) => document.getElementById(id);
    const table = byId('worksheet-table');
    const scoreCopy = byId('worksheet-score-copy');
    const adaptiveNote = byId('adaptive-note');
    const adaptiveNoteCopy = byId('adaptive-note-copy');
    const exerciseStateKey = 'soroban-dojo:exercise-states';
    let worksheetTimerStartedAt = null;
    let worksheetTimerInterval = null;

    const selectedFamilies = () => Array.from(document.querySelectorAll('input[name="worksheet-family"]:checked')).map((node) => node.value);
    const setMetric = (id, value) => { byId(id).textContent = String(value); };

    const solvePrompt = (prompt) => {
      const normalized = prompt.replace('×', '*').replace('÷', '/');
      const [left, operator, right] = normalized.split(' ');
      const a = Number(left);
      const b = Number(right);
      if (operator === '+') return a + b;
      if (operator === '-') return a - b;
      if (operator === '*') return a * b;
      if (operator === '/') return a / b;
      return null;
    };

    const renderVerticalPrompt = (prompt) => {
      const tokens = prompt.split(' ');
      const rows = [];
      for (let i = 0; i < tokens.length; i += 2) {
        const value = tokens[i];
        const operator = i === 0 ? '' : tokens[i - 1];
        rows.push(`<div class="v-arith-row"><span class="v-arith-op">${operator}</span><span class="v-arith-value">${value}</span></div>`);
      }
      rows.push('<div class="v-arith-line"></div>');
      return `<div class="v-arith-block">${rows.join('')}</div>`;
    };

    const parseBand = (band) => {
      if (band.includes('-')) {
        const [min, max] = band.split('-').map(Number);
        return { min, max };
      }
      const digits = Number(band);
      return { min: digits, max: digits };
    };

    const rand = (min, max) => Math.floor(Math.random() * (max - min + 1)) + min;
    const randomDigits = (band) => {
      const { min, max } = parseBand(band);
      return rand(min, max);
    };
    const randomNumberForDigits = (digits) => {
      const min = digits === 1 ? 1 : 10 ** (digits - 1);
      const max = (10 ** digits) - 1;
      return rand(min, max);
    };

    const chooseFamily = (level, selectedFamily) => {
      if (selectedFamily !== 'mixed') return selectedFamily;
      if (level === 'L0' || level === 'L1') return Math.random() > 0.5 ? 'addition' : 'subtraction';
      if (level === 'L4') return Math.random() > 0.5 ? 'multiplication' : 'division';
      return Math.random() > 0.5 ? 'addition' : 'subtraction';
    };

    const applyLevelDefaults = () => {
      const level = byId('worksheet-level').value;
      const defaults = {
        L0: ['addition', 'subtraction'],
        L1: ['addition', 'subtraction'],
        L2: ['mixed', 'sequence'],
        L3: ['mixed', 'sequence'],
        L4: ['multiplication', 'division'],
        L5: ['anzan', 'sequence'],
      };
      document.querySelectorAll('input[name="worksheet-family"]').forEach((node) => {
        node.checked = defaults[level].includes(node.value);
      });
      byId('worksheet-band').value = levelBands[level] || '2';
      if (['L2','L3','L5'].includes(level)) {
        byId('worksheet-orientation').value = 'vertical';
      } else {
        byId('worksheet-orientation').value = 'ledger';
      }
    };

    const autoAlignOrientation = () => {
      const families = selectedFamilies();
      const verticalPreferred = families.includes('sequence') || families.includes('anzan');
      if (verticalPreferred) byId('worksheet-orientation').value = 'vertical';
    };

    const readWeakAreas = () => {
      try {
        const states = JSON.parse(localStorage.getItem(exerciseStateKey) || '{}');
        const entries = Object.values(states).filter((entry) => entry?.status === 'needs-review');
        const counts = entries.reduce((acc, entry) => {
          if (entry.sessionId?.includes('L4')) acc.multiplication += 1;
          else if (entry.sessionId?.includes('L2')) acc.complements += 1;
          else acc.arithmetic += 1;
          return acc;
        }, { arithmetic: 0, complements: 0, multiplication: 0 });
        return counts;
      } catch {
        return { arithmetic: 0, complements: 0, multiplication: 0 };
      }
    };

    const describeWeakArea = (counts) => {
      if (counts.multiplication > counts.arithmetic && counts.multiplication > counts.complements) {
        return 'Recent practice suggests more support is needed in multiplication/division patterns.';
      }
      if (counts.complements > counts.arithmetic) {
        return 'Recent practice suggests more support is needed in complement and mental-balance work.';
      }
      return 'Recent practice suggests strengthening arithmetic rhythm and accuracy first.';
    };

    const styleAdjustBand = (style, band) => {
      if (style === 'speed') {
        if (band === '4-6') return '3-4';
        if (band === '3-4') return '2-3';
      }
      if (style === 'exam' && band === '2') return '2-3';
      return band;
    };

    const makeDynamicPrompt = (level, family, band, style) => {
      if (family === 'sequence' || family === 'anzan') {
        const digits = randomDigits(styleAdjustBand(style, band));
        const a = randomNumberForDigits(Math.max(1, Math.min(digits, level === 'L5' ? 4 : 3)));
        const b = randomNumberForDigits(Math.max(1, Math.min(digits, 2)));
        const c = randomNumberForDigits(1);
        const d = family === 'anzan' && level === 'L5' ? randomNumberForDigits(1) : null;
        return d ? `${a} + ${b} - ${c} + ${d}` : `${a} + ${b} - ${c}`;
      }
      const resolvedFamily = chooseFamily(level, family);
      const digits = randomDigits(styleAdjustBand(style, band));
      if (resolvedFamily === 'multiplication') {
        const a = randomNumberForDigits(Math.min(level === 'L5' ? 3 : 2, digits));
        const b = rand(2, level === 'L5' ? 12 : 9);
        return `${a} × ${b}`;
      }
      if (resolvedFamily === 'division') {
        const divisor = rand(2, level === 'L5' ? 12 : 9);
        const quotient = randomNumberForDigits(Math.max(1, Math.min(level === 'L5' ? 3 : 2, digits)));
        return `${divisor * quotient} ÷ ${divisor}`;
      }
      const aDigits = digits;
      const bDigits = Math.max(1, digits - (Math.random() > 0.5 ? 0 : 1));
      const a = randomNumberForDigits(aDigits);
      const bRaw = randomNumberForDigits(bDigits);
      if (resolvedFamily === 'addition') return `${a} + ${bRaw}`;
      const b = Math.min(bRaw, a);
      return `${a} - ${b}`;
    };

    const buildPrompts = () => {
      const mode = byId('worksheet-mode').value;
      const level = byId('worksheet-level').value;
      const families = selectedFamilies();
      const style = byId('worksheet-style').value;
      const count = Number(byId('worksheet-count').value);
      const band = byId('worksheet-band').value || levelBands[level] || '2';
      const bank = fixedBanks[level] || {};
      const fixedPool = families.flatMap((family) => bank[family] || []).filter(Boolean);
      const fixedFamily = fixedPool.length ? fixedPool : bank.mixed || Object.values(bank)[0] || [];
      if (mode === 'fixed') {
        return Array.from({ length: count }, (_, index) => fixedFamily[index % fixedFamily.length]);
      }
      if (mode === 'adaptive') {
        const weakAreas = readWeakAreas();
        const adaptiveFamily = weakAreas.multiplication > weakAreas.arithmetic
          ? 'multiplication'
          : weakAreas.complements > weakAreas.arithmetic
            ? 'anzan'
            : families[0] || 'addition';
        return Array.from({ length: count }, () => makeDynamicPrompt(level, adaptiveFamily, band, style));
      }
      return Array.from({ length: count }, (_, index) => makeDynamicPrompt(level, families[index % Math.max(1, families.length)] || 'addition', band, style));
    };

    const renderSheet = () => {
      const prompts = buildPrompts();
      const orientation = byId('worksheet-orientation').value;
      const ledgerHead = byId('worksheet-ledger-head');
      const teacherMode = byId('worksheet-style').value === 'teacher';
      const adaptiveMode = byId('worksheet-mode').value === 'adaptive';
      const teacherNote = byId('teacher-note');
      const weakAreas = readWeakAreas();
      table.replaceChildren();
      table.className = orientation === 'vertical' ? 'worksheet-table vertical-table' : 'worksheet-table ledger-table';
      table.closest('.ledger-panel')?.classList.toggle('teacher-mode', teacherMode);
      teacherNote.hidden = !teacherMode;
      adaptiveNote.hidden = !adaptiveMode;
      adaptiveNoteCopy.textContent = describeWeakArea(weakAreas);
      ledgerHead.hidden = orientation === 'vertical';
      if (orientation === 'vertical') {
        const columns = 5;
        const perColumn = Math.ceil(prompts.length / columns);
        for (let c = 0; c < columns; c += 1) {
          const col = document.createElement('div');
          col.className = 'vertical-drill-column';
          prompts.slice(c * perColumn, (c + 1) * perColumn).forEach((prompt, index) => {
            const absoluteIndex = c * perColumn + index;
            const row = document.createElement('label');
            row.className = 'vertical-drill-row';
            row.innerHTML = `
              <span class="ledger-no">${absoluteIndex + 1}</span>
              ${renderVerticalPrompt(prompt)}
              <input class="input worksheet-input vertical-input" data-prompt="${prompt}" type="text" inputmode="numeric" placeholder="Write" />
              <small class="worksheet-feedback vertical-feedback"></small>
              <div class="worksheet-row-actions"><button type="button" class="mini-action" data-row-action="check">Check</button><button type="button" class="mini-action" data-row-action="reveal">Reveal</button></div>
            `;
            col.appendChild(row);
          });
          table.appendChild(col);
        }
      } else {
        prompts.forEach((prompt, index) => {
          const row = document.createElement('label');
          row.className = 'ledger-row worksheet-row';
          row.innerHTML = `
            <span class="ledger-no">${index + 1}</span>
            <span class="worksheet-prompt ledger-prompt">${prompt}</span>
            <input class="input worksheet-input ledger-input" data-prompt="${prompt}" type="text" inputmode="numeric" placeholder="Write" />
            <small class="worksheet-feedback ledger-feedback"></small>
            <div class="worksheet-row-actions"><button type="button" class="mini-action" data-row-action="check">Check</button><button type="button" class="mini-action" data-row-action="reveal">Reveal</button></div>
          `;
          table.appendChild(row);
        });
      }
      const familyLabel = selectedFamilies().join(', ') || 'addition';
      const levelLabel = byId('worksheet-level').value;
      const bandLabel = byId('worksheet-band').value;
      byId('worksheet-title').textContent = `${levelLabel} ${familyLabel} ${orientation === 'vertical' ? 'columns' : 'ledger'} · ${bandLabel} digits`;
      byId('worksheet-count-badge').textContent = `${prompts.length} drills`;
      scoreCopy.textContent = teacherMode
        ? 'Teacher key mode is active. Print or reveal for guided review.'
        : adaptiveMode
        ? 'Adaptive mode favors your recent weak areas. Blank answers are skipped.'
        : 'No answers checked yet.';
      setMetric('worksheet-answered', 0);
      setMetric('worksheet-correct', 0);
      setMetric('worksheet-accuracy', '0%');
      setMetric('worksheet-completion', '0%');
    };

    const scoreSheet = (reveal = false) => {
      const inputs = Array.from(document.querySelectorAll('.worksheet-input'));
      let answered = 0;
      let correct = 0;
      inputs.forEach((input) => {
        const expected = solvePrompt(input.dataset.prompt);
        const feedback = input.parentElement.querySelector('.worksheet-feedback');
        const value = input.value.trim();
        if (!value) {
          feedback.textContent = '';
          feedback.className = 'worksheet-feedback ledger-feedback';
          return;
        }
        answered += 1;
        const isCorrect = Number(value) === expected;
        if (isCorrect) correct += 1;
        feedback.textContent = reveal ? `${expected}` : (isCorrect ? '✓' : '○');
        feedback.className = `worksheet-feedback ledger-feedback ${reveal ? 'revealed' : isCorrect ? 'ok' : 'needs-work'}`;
      });
      if (!answered) {
        scoreCopy.textContent = reveal ? 'Answers revealed for answered rows only. Blank rows were skipped.' : 'No answered rows yet. Blank rows are skipped.';
        setMetric('worksheet-answered', 0);
        setMetric('worksheet-correct', 0);
        setMetric('worksheet-accuracy', '0%');
        setMetric('worksheet-completion', '0%');
        return;
      }
      const percent = Math.round((correct / answered) * 100);
      const completion = Math.round((answered / inputs.length) * 100);
      scoreCopy.textContent = `${correct}/${answered} correct · ${percent}% answered score · ${completion}% completion`;
      setMetric('worksheet-answered', answered);
      setMetric('worksheet-correct', correct);
      setMetric('worksheet-accuracy', `${percent}%`);
      setMetric('worksheet-completion', `${completion}%`);
    };

    const scoreSingleRow = (row, reveal = false) => {
      const input = row.querySelector('.worksheet-input');
      const feedback = row.querySelector('.worksheet-feedback');
      if (!input || !feedback) return;
      const expected = solvePrompt(input.dataset.prompt);
      const value = input.value.trim();
      if (!value) {
        feedback.textContent = reveal ? `${expected}` : 'Write first';
        feedback.className = `worksheet-feedback ${reveal ? 'revealed' : 'needs-work'}`;
        return;
      }
      const isCorrect = Number(value) === expected;
      feedback.textContent = reveal ? `${expected}` : (isCorrect ? '✓' : '○');
      feedback.className = `worksheet-feedback ${reveal ? 'revealed' : isCorrect ? 'ok' : 'needs-work'}`;
    };

    const syncTimer = () => {
      if (!worksheetTimerStartedAt) return;
      const seconds = Math.max(0, Math.round((Date.now() - worksheetTimerStartedAt) / 1000));
      setMetric('worksheet-time', `${seconds}s`);
    };

    byId('worksheet-timer-toggle')?.addEventListener('click', () => {
      if (byId('worksheet-timer-mode').value === 'off') return;
      if (worksheetTimerStartedAt) {
        window.clearInterval(worksheetTimerInterval);
        worksheetTimerInterval = null;
        worksheetTimerStartedAt = null;
        byId('worksheet-timer-toggle').textContent = 'Start timer';
        return;
      }
      worksheetTimerStartedAt = Date.now();
      byId('worksheet-timer-toggle').textContent = 'Pause timer';
      syncTimer();
      worksheetTimerInterval = window.setInterval(syncTimer, 1000);
    });

    byId('worksheet-timer-mode')?.addEventListener('change', () => {
      if (byId('worksheet-timer-mode').value === 'off') {
        window.clearInterval(worksheetTimerInterval);
        worksheetTimerInterval = null;
        worksheetTimerStartedAt = null;
        byId('worksheet-timer-toggle').textContent = 'Start timer';
        setMetric('worksheet-time', '0s');
      }
    });

    byId('worksheet-level')?.addEventListener('change', () => {
      applyLevelDefaults();
      renderSheet();
    });
    byId('generate-worksheet')?.addEventListener('click', renderSheet);
    byId('check-worksheet')?.addEventListener('click', () => scoreSheet(false));
    byId('reveal-worksheet')?.addEventListener('click', () => scoreSheet(true));
    byId('teacher-key')?.addEventListener('click', () => {
      byId('worksheet-style').value = 'teacher';
      renderSheet();
      scoreSheet(true);
    });
    document.querySelectorAll('input[name="worksheet-family"]').forEach((node) => {
      node.addEventListener('change', () => {
        autoAlignOrientation();
        renderSheet();
      });
    });
    table.addEventListener('click', (event) => {
      const button = event.target.closest('[data-row-action]');
      if (!button) return;
      const row = button.closest('.ledger-row, .vertical-drill-row');
      if (!row) return;
      scoreSingleRow(row, button.dataset.rowAction === 'reveal');
    });
    document.querySelectorAll('#worksheet-mode, #worksheet-level, #worksheet-family, #worksheet-band, #worksheet-style, #worksheet-orientation, #worksheet-count').forEach((node) => {
      node.addEventListener('change', renderSheet);
    });
    applyLevelDefaults();
    setMetric('worksheet-time', '0s');
    renderSheet();
  </script>
</BaseLayout>
