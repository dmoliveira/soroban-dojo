---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Printable Soroban Worksheets | Soroban Dojo" description="Generate printable Soroban and abacus worksheets by level, digit band, and skill pattern with student-sheet and answer-key modes in ai-soroban.">
  <section class="panel content-prose no-print">
    <p class="eyebrow">Soroban sheets · 印刷</p>
    <h1>Ledger-style drill sheets</h1>
    <p>Choose a fixed curriculum sheet or generate a denser practice ledger by level, operation family, and digit band. Blank responses are skipped; partial score uses only answered drills.</p>

    <div class="worksheet-preset-row">
      <button class="button button-secondary preset-button" data-preset="warmup">Warm-up</button>
      <button class="button button-secondary preset-button" data-preset="practice">Practice</button>
      <button class="button button-secondary preset-button" data-preset="review">Review</button>
      <button class="button button-secondary preset-button" data-preset="speed">Speed</button>
      <button class="button button-secondary preset-button" data-preset="exam">Exam</button>
      <button class="button button-secondary preset-button" data-preset="foundations-focus">Foundations</button>
      <button class="button button-secondary preset-button" data-preset="one-rod-focus">One-rod</button>
      <button class="button button-secondary preset-button" data-preset="mixed-fluency">Mixed fluency</button>
      <button class="button button-secondary preset-button" data-preset="multiplication-focus">Multiplication</button>
      <button class="button button-secondary preset-button" data-preset="division-focus">Division</button>
      <button class="button button-secondary preset-button" data-preset="anzan-focus">Anzan</button>
      <button class="button button-secondary preset-button" data-preset="carry">Carry</button>
      <button class="button button-secondary preset-button" data-preset="borrow">Borrow</button>
      <button class="button button-secondary preset-button" data-preset="complements">Complements</button>
      <button class="button button-secondary preset-button" data-preset="sequence-mix">Sequence mix</button>
    </div>

    <div class="ledger-controls worksheet-controls-shell">
      <div class="worksheet-controls-grid worksheet-controls-grid-main">
      <label class="stack-sm">
        <span>Sheet mode</span>
        <select id="worksheet-mode" class="select">
          <option value="fixed">Fixed sheet</option>
          <option value="dynamic">Dynamic ledger</option>
          <option value="adaptive">Adaptive ledger</option>
        </select>
      </label>
      <label class="stack-sm">
        <span>Level</span>
        <select id="worksheet-level" class="select">
          <option value="L0">L0 Foundations</option>
          <option value="L1">L1 Beginner</option>
          <option value="L2">L2 Complements</option>
          <option value="L3">L3 Mixed</option>
          <option value="L4">L4 Multiplication & division</option>
          <option value="L5">L5 Mastery</option>
        </select>
      </label>
      <fieldset class="stack-sm worksheet-operation-group">
        <legend>Operation family</legend>
        <div class="operation-chip-grid">
          <label class="operation-chip"><input type="checkbox" name="worksheet-family" value="addition" checked />Addition</label>
          <label class="operation-chip"><input type="checkbox" name="worksheet-family" value="subtraction" />Subtraction</label>
          <label class="operation-chip"><input type="checkbox" name="worksheet-family" value="mixed" />Mixed</label>
          <label class="operation-chip"><input type="checkbox" name="worksheet-family" value="sequence" />Sequence</label>
          <label class="operation-chip"><input type="checkbox" name="worksheet-family" value="multiplication" />Multiplication</label>
          <label class="operation-chip"><input type="checkbox" name="worksheet-family" value="division" />Division</label>
          <label class="operation-chip"><input type="checkbox" name="worksheet-family" value="anzan" />Anzan / mental</label>
        </div>
      </fieldset>
      <label class="stack-sm">
        <span>Drill focus</span>
        <select id="worksheet-submode" class="select">
          <option value="auto" selected>Auto focus</option>
          <option value="arithmetic-rhythm">Arithmetic rhythm</option>
          <option value="complement-balance">Complement balance</option>
          <option value="sequence-signs">Sequence sign changes</option>
          <option value="table-family">Multiplication table family</option>
          <option value="place-shifts">Multiplication place shifts</option>
          <option value="division-facts">Division fact families</option>
          <option value="quotient-building">Division quotient building</option>
          <option value="anzan-recall">Mental recall</option>
        </select>
      </label>
      <label class="stack-sm">
        <span>Digit band</span>
        <select id="worksheet-band" class="select">
          <option value="1">1 digit</option>
          <option value="2">2 digits</option>
          <option value="3">3 digits</option>
          <option value="4">4 digits</option>
          <option value="1-2">1–2 digits</option>
          <option value="2-3" selected>2–3 digits</option>
          <option value="2-4">2–4 digits</option>
          <option value="3-4">3–4 digits</option>
          <option value="4-6">4–6 digits</option>
        </select>
        <small id="worksheet-band-guide" class="muted small">Every displayed operand will stay inside this digit band.</small>
      </label>
      </div>
      <details class="worksheet-advanced-block">
        <summary>Advanced options</summary>
        <div class="worksheet-controls-grid worksheet-controls-grid-advanced">
          <label class="stack-sm">
            <span>Sheet type</span>
            <select id="worksheet-style" class="select">
              <option value="practice">Practice</option>
              <option value="speed">Speed</option>
              <option value="review">Review</option>
              <option value="exam">Exam</option>
              <option value="teacher">Teacher key</option>
            </select>
          </label>
          <label class="stack-sm">
            <span>Orientation</span>
            <select id="worksheet-orientation" class="select">
              <option value="ledger" selected>Ledger rows</option>
              <option value="vertical">Vertical columns</option>
            </select>
          </label>
          <label class="stack-sm">
            <span>Drills</span>
            <select id="worksheet-count" class="select">
              <option value="20">20</option>
              <option value="40" selected>40</option>
              <option value="60">60</option>
              <option value="100">100</option>
            </select>
          </label>
          <label class="stack-sm">
            <span>Stopwatch</span>
            <select id="worksheet-timer-mode" class="select">
              <option value="off">Off</option>
              <option value="on">On</option>
            </select>
          </label>
          <label class="stack-sm">
            <span>Difficulty flow</span>
            <select id="worksheet-flow-mode" class="select">
              <option value="balanced">Balanced variety</option>
              <option value="ramp">Ramp up through the sheet</option>
            </select>
          </label>
          <label class="stack-sm">
            <span>Print mode</span>
            <select id="worksheet-print-mode" class="select">
              <option value="student">Student sheet</option>
              <option value="answer-key">Answer key</option>
            </select>
          </label>
        </div>
      </details>
    </div>

    <div class="worksheet-toolbar-actions">
      <div class="button-row worksheet-action-row worksheet-action-row-primary">
        <button class="button" id="generate-worksheet">Generate ledger</button>
        <button class="button button-secondary" id="check-worksheet">Check answered</button>
        <button class="button button-secondary" id="reveal-worksheet">Reveal answers</button>
      </div>
      <div class="button-row worksheet-action-row worksheet-action-row-secondary">
        <button class="button button-secondary" id="teacher-key">Teacher key</button>
        <button class="button button-secondary" id="worksheet-timer-toggle">Start timer</button>
        <button class="button button-secondary" id="print-worksheet">Print sheet</button>
        <a class="button button-secondary" href={`${base}practice`}>Return to practice</a>
      </div>
    </div>
    <div class="worksheet-current-setup subtle-panel">
      <strong>Current setup</strong>
      <div id="worksheet-current-setup-copy" class="muted small">L0 · fixed · addition/subtraction · 1 digit · ledger</div>
      <div id="worksheet-band-summary" class="muted small">Each shown operand stays in the selected digit band.</div>
      <div id="worksheet-target-summary" class="muted small">Focus target: auto</div>
    </div>

    <div class="worksheet-scorebar subtle-panel" id="worksheet-scorebar">
      <strong>Score</strong>
      <span id="worksheet-score-copy" class="muted">No answers checked yet.</span>
    </div>
    <div id="worksheet-celebration" class="worksheet-celebration" hidden>
      <strong>Congratulations</strong>
      <span>You completed the full sheet with perfect accuracy.</span>
    </div>
    <div class="worksheet-score-grid">
      <article class="stat-card stat-card-soft"><span id="worksheet-answered">0</span><small>Answered</small></article>
      <article class="stat-card stat-card-soft"><span id="worksheet-correct">0</span><small>Correct</small></article>
      <article class="stat-card stat-card-soft"><span id="worksheet-accuracy">0%</span><small>Accuracy</small></article>
      <article class="stat-card stat-card-soft"><span id="worksheet-completion">0%</span><small>Completion</small></article>
      <article class="stat-card stat-card-soft"><span id="worksheet-time">0s</span><small>Time</small></article>
    </div>
    <div class="worksheet-note-strip">
      <div id="adaptive-note" class="subtle-panel worksheet-note-panel no-print" hidden>
        <strong>Adaptive recommendation</strong>
        <p id="adaptive-note-copy" class="muted">This sheet is tuned to your recent weak areas stored in local progress.</p>
      </div>
      <div id="teacher-note" class="subtle-panel worksheet-note-panel no-print" hidden>
        <strong>Teacher view</strong>
        <p class="muted">Use this mode to print answer keys or review drills aloud. Answers remain visible while blank student rows are left untouched.</p>
      </div>
    </div>
  </section>

  <section class="worksheet-board">
    <article class="panel worksheet-panel ledger-panel">
      <div class="section-head">
        <div>
          <p class="eyebrow">Drill ledger</p>
          <h2 id="worksheet-title">Standard Soroban drill set</h2>
        </div>
        <span class="badge" id="worksheet-count-badge">40 drills</span>
      </div>
      <div id="worksheet-ledger-head" class="ledger-head ledger-row">
        <span>No.</span>
        <span>Drill</span>
        <span>Response</span>
        <span>Result</span>
        <span>Actions</span>
      </div>
      <div id="worksheet-table" class="worksheet-table ledger-table"></div>
    </article>
  </section>

  <script is:inline>
    const fixedBanks = {
      L0: {
        addition: ['1 + 2','2 + 1','2 + 2','3 + 1','4 + 1','1 + 3','2 + 3','3 + 2','4 + 2','5 + 1'],
        subtraction: ['4 - 1','5 - 2','6 - 1','7 - 3','8 - 2','6 - 2','7 - 1','8 - 4','9 - 3','9 - 2'],
      },
      L1: {
        addition: ['12 + 5','24 + 7','31 + 4','18 + 6','42 + 13','25 + 11','33 + 14','47 + 21','51 + 8','62 + 17'],
        subtraction: ['24 - 7','31 - 4','18 - 6','42 - 13','55 - 12','63 - 21','80 - 15','74 - 32','91 - 18','64 - 9'],
      },
      L2: {
        mixed: ['24 + 7','31 - 4','18 + 5','42 - 11','25 + 6','36 - 12','27 + 8','44 - 9','52 - 18','19 + 14'],
        sequence: ['12 + 5 - 3','24 - 7 + 6','18 + 5 + 2','42 - 11 + 4','25 + 6 - 4','36 - 12 + 5','27 + 8 - 6','44 - 9 + 3','52 - 18 + 7','19 + 14 - 9'],
      },
      L3: {
        mixed: ['124 + 37','231 - 44','318 + 56','442 - 111','205 + 16','360 - 124','274 + 88','440 - 95','520 - 184','193 + 147'],
        sequence: ['124 + 37 - 15','231 - 44 + 18','318 + 56 - 21','442 - 111 + 24','205 + 16 + 19','360 - 124 + 37','274 + 88 - 46','440 - 95 + 18','520 - 184 + 29','193 + 147 - 58'],
      },
      L4: {
        multiplication: ['3 × 4','4 × 3','12 × 2','5 × 12','13 × 5','6 × 12','14 × 4','3 × 16','17 × 2','15 × 3'],
        division: ['12 ÷ 3','12 ÷ 4','40 ÷ 5','45 ÷ 5','36 ÷ 6','48 ÷ 6','56 ÷ 7','63 ÷ 9','72 ÷ 8','81 ÷ 9'],
      },
      L5: {
        mixed: ['1245 + 378','2318 - 444','3186 + 567','4420 - 1114','2057 + 168','3604 - 1248','2745 + 889','4400 - 955','5208 - 1842','1937 + 1476'],
        anzan: ['18 + 7 + 5','24 - 6 + 8','37 + 14 - 9','45 - 8 + 6','63 + 12 - 15','72 - 18 + 9','84 + 15 - 11','96 - 24 + 8','128 + 37 - 15','205 - 18 + 27'],
      },
    };

    const levelBands = {
      L0: '1',
      L1: '2',
      L2: '2-3',
      L3: '3-4',
      L4: '2-4',
      L5: '4-6',
    };

    const presets = {
      warmup: { mode: 'fixed', level: 'L0', families: ['addition', 'subtraction'], band: '1', style: 'practice', orientation: 'ledger', count: '20' },
      'foundations-focus': { mode: 'fixed', level: 'L0', families: ['addition', 'subtraction'], band: '1', style: 'practice', orientation: 'ledger', count: '20' },
      'one-rod-focus': { mode: 'fixed', level: 'L1', families: ['addition', 'subtraction'], band: '2', style: 'practice', orientation: 'ledger', count: '20' },
      practice: { mode: 'dynamic', level: 'L2', families: ['mixed', 'sequence'], band: '2-3', style: 'practice', orientation: 'vertical', count: '40', flowMode: 'balanced' },
      'mixed-fluency': { mode: 'dynamic', level: 'L3', families: ['mixed', 'sequence'], band: '3-4', style: 'practice', orientation: 'vertical', count: '40', flowMode: 'ramp' },
      review: { mode: 'adaptive', level: 'L2', families: ['mixed', 'sequence'], band: '2-3', style: 'review', orientation: 'vertical', count: '40', submode: 'auto' },
      speed: { mode: 'dynamic', level: 'L3', families: ['addition', 'subtraction'], band: '2-3', style: 'speed', orientation: 'ledger', count: '60' },
      exam: { mode: 'dynamic', level: 'L4', families: ['multiplication', 'division', 'sequence'], band: '3-4', style: 'exam', orientation: 'vertical', count: '40', flowMode: 'ramp' },
      'multiplication-focus': { mode: 'dynamic', level: 'L4', families: ['multiplication'], band: '2-4', style: 'practice', orientation: 'ledger', count: '40', flowMode: 'ramp', submode: 'place-shifts' },
      'division-focus': { mode: 'dynamic', level: 'L4', families: ['division'], band: '2-4', style: 'review', orientation: 'ledger', count: '40', flowMode: 'ramp', submode: 'quotient-building' },
      'anzan-focus': { mode: 'dynamic', level: 'L5', families: ['anzan', 'sequence'], band: '4-6', style: 'review', orientation: 'vertical', count: '40', flowMode: 'ramp', submode: 'anzan-recall' },
      carry: { mode: 'dynamic', level: 'L2', families: ['addition'], band: '2-3', style: 'practice', orientation: 'vertical', count: '40', flowMode: 'ramp' },
      borrow: { mode: 'dynamic', level: 'L2', families: ['subtraction'], band: '2-3', style: 'practice', orientation: 'vertical', count: '40', flowMode: 'ramp' },
      complements: { mode: 'dynamic', level: 'L2', families: ['anzan'], band: '2-3', style: 'review', orientation: 'ledger', count: '40', submode: 'complement-balance' },
      'sequence-mix': { mode: 'dynamic', level: 'L3', families: ['sequence', 'mixed'], band: '3-4', style: 'practice', orientation: 'vertical', count: '40', flowMode: 'ramp', submode: 'sequence-signs' },
    };

    const byId = (id) => document.getElementById(id);
    const table = byId('worksheet-table');
    const scoreCopy = byId('worksheet-score-copy');
    const celebration = byId('worksheet-celebration');
    const adaptiveNote = byId('adaptive-note');
    const adaptiveNoteCopy = byId('adaptive-note-copy');
    const currentSetupCopy = byId('worksheet-current-setup-copy');
    const exerciseStateKey = 'soroban-dojo:exercise-states';
    let worksheetTimerStartedAt = null;
    let worksheetTimerInterval = null;
    let celebrationTimeout = null;
    let resolvedWorksheetTarget = 'auto';
    const audioWindow = typeof window !== 'undefined' ? /** @type {any} */ (window) : null;
    const AudioContextCtor = audioWindow
      ? audioWindow.AudioContext || (audioWindow).webkitAudioContext || null
      : null;
    const audioCtx = AudioContextCtor ? new AudioContextCtor() : null;
    const playTone = (type) => {
      if (!audioCtx) return;
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.type = 'sine';
      const start = audioCtx.currentTime;
      const freqA = type === 'success' ? 660 : 280;
      const freqB = type === 'success' ? 880 : 220;
      osc.frequency.setValueAtTime(freqA, start);
      osc.frequency.linearRampToValueAtTime(freqB, start + 0.16);
      gain.gain.setValueAtTime(0.0001, start);
      gain.gain.linearRampToValueAtTime(0.028, start + 0.02);
      gain.gain.exponentialRampToValueAtTime(0.0001, start + 0.2);
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      osc.start();
      osc.stop(start + 0.22);
    };
    const setPrintMode = () => {
      document.documentElement.dataset.worksheetPrintMode = byId('worksheet-print-mode')?.value || 'student';
    };

    const selectedFamilies = () => Array.from(document.querySelectorAll('input[name="worksheet-family"]:checked')).map((node) => node.value);
    const setMetric = (id, value) => { byId(id).textContent = String(value); };

    const solvePrompt = (prompt) => {
      const normalized = prompt.replace('×', '*').replace('÷', '/');
      const tokens = normalized.split(' ');
      if (tokens.length < 3) return null;
      let total = Number(tokens[0]);
      for (let i = 1; i < tokens.length; i += 2) {
        const operator = tokens[i];
        const value = Number(tokens[i + 1]);
        if (Number.isNaN(total) || Number.isNaN(value)) return null;
        if (operator === '+') total += value;
        else if (operator === '-') total -= value;
        else if (operator === '*') total *= value;
        else if (operator === '/') total /= value;
        else return null;
      }
      return total;
    };

    const renderVerticalPrompt = (prompt) => {
      const tokens = prompt.split(' ');
      const rows = [];
      for (let i = 0; i < tokens.length; i += 2) {
        const value = tokens[i];
        const operator = i === 0 ? '' : tokens[i - 1];
        rows.push(`<div class="v-arith-row"><span class="v-arith-op">${operator}</span><span class="v-arith-value">${value}</span></div>`);
      }
      rows.push('<div class="v-arith-line"></div>');
      return `<div class="v-arith-block">${rows.join('')}</div>`;
    };

    const parseBand = (band) => {
      if (band.includes('-')) {
        const [min, max] = band.split('-').map(Number);
        return { min, max };
      }
      const digits = Number(band);
      return { min: digits, max: digits };
    };

    const rand = (min, max) => Math.floor(Math.random() * (max - min + 1)) + min;
    const shuffle = (items) => {
      const copy = [...items];
      for (let index = copy.length - 1; index > 0; index -= 1) {
        const swapIndex = rand(0, index);
        [copy[index], copy[swapIndex]] = [copy[swapIndex], copy[index]];
      }
      return copy;
    };
    const randomNumberForDigits = (digits) => {
      const min = digits === 1 ? 1 : 10 ** (digits - 1);
      const max = (10 ** digits) - 1;
      return rand(min, max);
    };
    const minValueForDigits = (digits) => (digits === 1 ? 1 : 10 ** (digits - 1));
    const maxValueForDigits = (digits) => (10 ** digits) - 1;
    const digitLength = (value) => String(Math.abs(value)).length;
    const randomNumberForDigitsWhere = (digits, predicate) => {
      for (let attempt = 0; attempt < 40; attempt += 1) {
        const candidate = randomNumberForDigits(digits);
        if (predicate(candidate)) return candidate;
      }
      return null;
    };
    const pickDigitsForVariant = (bandRange, variant) => {
      if (bandRange.min === bandRange.max) return bandRange.min;
      const spread = bandRange.max - bandRange.min;
      if (variant % 4 === 0) return bandRange.max;
      if (variant % 4 === 1) return bandRange.min;
      if (variant % 4 === 2) return Math.max(bandRange.min, bandRange.max - 1);
      return bandRange.min + rand(0, spread);
    };
    const buildAdditionPrompt = (bandRange, variant) => {
      const aDigits = pickDigitsForVariant(bandRange, variant);
      const bDigits = pickDigitsForVariant({ min: bandRange.min, max: aDigits }, variant + 1);
      const aFallback = randomNumberForDigits(aDigits);
      const bFallback = randomNumberForDigits(bDigits);

      if (variant % 4 === 0) {
        const a = randomNumberForDigitsWhere(aDigits, (value) => value % 10 >= 6) ?? aFallback;
        const b = randomNumberForDigitsWhere(bDigits, (value) => value % 10 >= 4) ?? bFallback;
        return `${a} + ${b}`;
      }
      if (variant % 4 === 1) {
        const aOnes = rand(1, 9);
        const bOnes = 10 - aOnes;
        const a = randomNumberForDigitsWhere(aDigits, (value) => value % 10 === aOnes) ?? aFallback;
        const b = randomNumberForDigitsWhere(bDigits, (value) => value % 10 === bOnes) ?? bFallback;
        return `${a} + ${b}`;
      }
      if (variant % 4 === 2) {
        const a = randomNumberForDigits(aDigits);
        const offset = rand(1, Math.max(3, 10 ** Math.max(0, bDigits - 1)));
        const bMin = minValueForDigits(bDigits);
        const bMax = maxValueForDigits(bDigits);
        const b = Math.max(bMin, Math.min(bMax, a + (variant % 2 === 0 ? offset : -offset)));
        return `${a} + ${b}`;
      }
      const a = randomNumberForDigits(bandRange.max);
      const b = randomNumberForDigits(bandRange.min);
      return `${a} + ${b}`;
    };
    const buildSubtractionPrompt = (bandRange, variant) => {
      const aDigits = pickDigitsForVariant(bandRange, variant);
      const bDigits = pickDigitsForVariant({ min: bandRange.min, max: aDigits }, variant + 1);
      const genericA = randomNumberForDigits(aDigits);
      const genericB = Math.min(randomNumberForDigits(bDigits), genericA);

      if (variant % 4 === 0) {
        const a = randomNumberForDigitsWhere(aDigits, (value) => value % 10 <= 3 && value > minValueForDigits(bDigits)) ?? genericA;
        const b = randomNumberForDigitsWhere(bDigits, (value) => value < a && value % 10 >= 4) ?? Math.min(randomNumberForDigits(bDigits), a);
        return `${a} - ${b}`;
      }
      if (variant % 4 === 1) {
        const b = randomNumberForDigits(bDigits);
        const aMin = Math.max(minValueForDigits(aDigits), b + 5);
        const aMax = Math.min(maxValueForDigits(aDigits), b + Math.max(12, minValueForDigits(bDigits)));
        if (aMin <= aMax) return `${rand(aMin, aMax)} - ${b}`;
      }
      if (variant % 4 === 2) {
        const a = randomNumberForDigits(bandRange.max);
        const b = Math.min(randomNumberForDigits(bandRange.min), a - 1);
        return `${a} - ${Math.max(1, b)}`;
      }
      return `${genericA} - ${genericB}`;
    };
    const buildSequencePrompt = (family, bandRange, variant) => {
      const patterns = family === 'anzan'
        ? [['+', '-', '+'], ['+', '+', '-'], ['-', '+', '+'], ['+', '-', '+', '+']]
        : [['+', '-'], ['-', '+'], ['+', '+', '-'], ['+', '-', '+'], ['-', '+', '+']];
      const pattern = patterns[variant % patterns.length];
      const startDigits = pattern.includes('-') ? bandRange.max : pickDigitsForVariant(bandRange, variant);
      const startMin = pattern.includes('-') ? Math.max(minValueForDigits(startDigits), Math.floor(maxValueForDigits(startDigits) * 0.55)) : minValueForDigits(startDigits);
      let total = rand(startMin, maxValueForDigits(startDigits));
      const parts = [String(total)];

      pattern.forEach((operator, index) => {
        if (operator === '+') {
          const addDigits = pickDigitsForVariant(bandRange, variant + index + 1);
          const value = randomNumberForDigits(addDigits);
          total += value;
          parts.push('+', String(value));
          return;
        }

        const maxSubtractDigits = Math.min(bandRange.max, digitLength(Math.max(total - minValueForDigits(bandRange.min), 0)));
        if (maxSubtractDigits < bandRange.min) {
          const value = randomNumberForDigits(pickDigitsForVariant(bandRange, variant + index + 1));
          total += value;
          parts.push('+', String(value));
          return;
        }

        const subtractDigits = pickDigitsForVariant({ min: bandRange.min, max: maxSubtractDigits }, variant + index + 1);
        const minimumRemainder = minValueForDigits(Math.min(bandRange.min, digitLength(total)));
        const value = randomNumberForDigitsWhere(subtractDigits, (candidate) => candidate < total && total - candidate >= minimumRemainder);
        if (value === null) {
          const fallback = randomNumberForDigits(pickDigitsForVariant(bandRange, variant + index + 1));
          total += fallback;
          parts.push('+', String(fallback));
          return;
        }

        total -= value;
        parts.push('-', String(value));
      });

      return parts.join(' ');
    };

    const chooseFamily = (level, selectedFamily, variant = 0) => {
      if (selectedFamily !== 'mixed') return selectedFamily;
      if (level === 'L0' || level === 'L1') return variant % 2 === 0 ? 'addition' : 'subtraction';
      if (level === 'L4') return variant % 2 === 0 ? 'multiplication' : 'division';
      return variant % 2 === 0 ? 'addition' : 'subtraction';
    };

    const applyLevelDefaults = () => {
      const level = byId('worksheet-level').value;
      const defaults = {
        L0: ['addition', 'subtraction'],
        L1: ['addition', 'subtraction'],
        L2: ['mixed', 'sequence'],
        L3: ['mixed', 'sequence'],
        L4: ['multiplication', 'division'],
        L5: ['anzan', 'sequence'],
      };
      document.querySelectorAll('input[name="worksheet-family"]').forEach((node) => {
        node.checked = defaults[level].includes(node.value);
      });
      byId('worksheet-band').value = levelBands[level] || '2';
      if (['L2','L3','L5'].includes(level)) {
        byId('worksheet-orientation').value = 'vertical';
      } else {
        byId('worksheet-orientation').value = 'ledger';
      }
    };

    const applyPreset = (key) => {
      const preset = presets[key];
      if (!preset) return;
      byId('worksheet-mode').value = preset.mode;
      byId('worksheet-level').value = preset.level;
      byId('worksheet-band').value = preset.band;
      byId('worksheet-style').value = preset.style;
      byId('worksheet-orientation').value = preset.orientation;
      byId('worksheet-count').value = preset.count;
      byId('worksheet-flow-mode').value = preset.flowMode || 'balanced';
      byId('worksheet-submode').value = preset.submode || 'auto';
      document.querySelectorAll('input[name="worksheet-family"]').forEach((node) => {
        node.checked = preset.families.includes(node.value);
      });
      renderSheet();
    };

    const autoAlignOrientation = () => {
      const families = selectedFamilies();
      const verticalPreferred = families.includes('sequence') || families.includes('anzan');
      if (verticalPreferred) byId('worksheet-orientation').value = 'vertical';
    };

    const readWeakAreas = () => {
      try {
        const states = JSON.parse(localStorage.getItem(exerciseStateKey) || '{}');
        const entries = Object.values(states).filter((entry) => entry?.status === 'needs-review');
        const counts = entries.reduce((acc, entry) => {
          const skill = entry.skill || '';
          const level = entry.level || '';
          const sessionId = entry.sessionId || '';
          if (skill === 'multiplication') acc.multiplication += 1;
          else if (skill === 'division') acc.division += 1;
          else if (skill === 'anzan' || skill === 'mastery') acc.mental += 1;
          else if (skill === 'complements') acc.complements += 1;
          else if (level === 'L4' || sessionId.includes('L4')) acc.multiplication += 1;
          else if (level === 'L5' || sessionId.includes('L5')) acc.mental += 1;
          else if (level === 'L2' || sessionId.includes('L2')) acc.complements += 1;
          else acc.arithmetic += 1;
          return acc;
        }, { arithmetic: 0, complements: 0, multiplication: 0, division: 0, mental: 0 });
        return counts;
      } catch {
        return { arithmetic: 0, complements: 0, multiplication: 0, division: 0, mental: 0 };
      }
    };

    const describeWeakArea = (counts) => {
      if (counts.mental > counts.arithmetic && counts.mental > counts.complements && counts.mental > counts.multiplication && counts.mental > counts.division) {
        return 'Recent practice suggests more support is needed in mental recall, sign changes, and anzan stability.';
      }
      if (counts.division > counts.arithmetic && counts.division >= counts.multiplication && counts.division > counts.complements) {
        return 'Recent practice suggests more support is needed in quotient building and division fact families.';
      }
      if (counts.multiplication > counts.arithmetic && counts.multiplication > counts.complements) {
        return 'Recent practice suggests more support is needed in multiplication/division patterns.';
      }
      if (counts.complements > counts.arithmetic) {
        return 'Recent practice suggests more support is needed in complement and mental-balance work.';
      }
      return 'Recent practice suggests strengthening arithmetic rhythm and accuracy first.';
    };

    const resolveAdaptiveTarget = (counts) => {
      const ordered = [
        ['mental', counts.mental],
        ['division', counts.division],
        ['multiplication', counts.multiplication],
        ['complements', counts.complements],
        ['arithmetic', counts.arithmetic],
      ].sort((a, b) => b[1] - a[1]);
      return ordered[0][0];
    };

    const styleAdjustBand = (style, band) => {
      if (style === 'speed') {
        if (band === '4-6') return '3-4';
        if (band === '3-4') return '2-3';
      }
      if (style === 'exam' && band === '2') return '2-3';
      return band;
    };

    const digitBandForProgress = (bandRange, count, index, flowMode) => {
      if (flowMode !== 'ramp' || bandRange.min === bandRange.max) return bandRange;
      const progress = count <= 1 ? 1 : index / (count - 1);
      const threshold = bandRange.max > bandRange.min ? 0.45 : 1;
      if (progress < threshold) {
        return { min: bandRange.min, max: Math.max(bandRange.min, bandRange.max - 1) };
      }
      if (progress < 0.8) {
        return { min: Math.max(bandRange.min, bandRange.max - 1), max: bandRange.max };
      }
      return { min: bandRange.max, max: bandRange.max };
    };

    const buildMultiplicationPrompt = (level, digits, variant, submode) => {
      const factorDigits = Math.min(level === 'L5' ? 3 : 2, pickDigitsForVariant({ min: 1, max: digits }, variant));
      if (submode === 'table-family') {
        const table = [3, 4, 5, 6, 7, 8, 9][variant % 7];
        const multiplicand = randomNumberForDigits(Math.max(1, Math.min(factorDigits, digits === 1 ? 1 : factorDigits)));
        return `${multiplicand} × ${table}`;
      }
      if (submode === 'place-shifts') {
        const tensBase = rand(1, 9) * 10;
        const ones = digits > 1 ? rand(2, 8) : rand(2, 4);
        const multiplicand = tensBase + ones;
        const multiplier = rand(2, level === 'L5' ? 9 : 6);
        return `${multiplicand} × ${multiplier}`;
      }
      const a = randomNumberForDigits(factorDigits);
      const b = variant % 2 === 0 ? rand(2, level === 'L5' ? 12 : 9) : rand(3, level === 'L5' ? 11 : 8);
      return `${a} × ${b}`;
    };

    const buildDivisionPrompt = (level, digits, variant, submode) => {
      if (submode === 'division-facts') {
        const divisor = [3, 4, 5, 6, 7, 8, 9][variant % 7];
        const quotient = rand(2, level === 'L5' ? 12 : 9);
        return `${divisor * quotient} ÷ ${divisor}`;
      }
      if (submode === 'quotient-building') {
        const divisor = rand(4, level === 'L5' ? 12 : 9);
        const quotient = rand(3, Math.min(9, maxValueForDigits(Math.max(1, Math.min(2, digits)))));
        return `${divisor * quotient} ÷ ${divisor}`;
      }
      const divisor = variant % 2 === 0 ? rand(2, level === 'L5' ? 12 : 9) : rand(3, level === 'L5' ? 11 : 8);
      const quotient = randomNumberForDigits(Math.max(1, Math.min(level === 'L5' ? 3 : 2, pickDigitsForVariant({ min: 1, max: digits }, variant + 1))));
      return `${divisor * quotient} ÷ ${divisor}`;
    };

    const makeDynamicPrompt = (level, family, band, style, variant = 0, flowBand = null, submode = 'auto') => {
      const adjustedBand = styleAdjustBand(style, band);
      const bandRange = flowBand || parseBand(adjustedBand);

      if (family === 'sequence' || family === 'anzan') {
        return buildSequencePrompt(family, bandRange, variant);
      }
      const resolvedFamily = chooseFamily(level, family, variant);
      const digits = rand(bandRange.min, bandRange.max);
      if (resolvedFamily === 'multiplication') {
        return buildMultiplicationPrompt(level, digits, variant, submode);
      }
      if (resolvedFamily === 'division') {
        return buildDivisionPrompt(level, digits, variant, submode);
      }
      if (resolvedFamily === 'addition') return buildAdditionPrompt({ min: bandRange.min, max: digits }, variant);
      return buildSubtractionPrompt({ min: bandRange.min, max: digits }, variant);
    };

    const promptStructureSignature = (prompt) => {
      const tokens = prompt.split(' ');
      const parts = [];
      for (let index = 0; index < tokens.length; index += 2) {
        const value = tokens[index];
        const operator = index === 0 ? 'start' : tokens[index - 1];
        parts.push(`${operator}:${String(value).length}`);
      }
      return parts.join('|');
    };

    const buildUniquePrompts = (count, createPrompt) => {
      const prompts = [];
      const seen = new Set();
      const structureCounts = new Map();
      let attempts = 0;
      const maxAttempts = Math.max(count * 120, 600);
      const maxStructureRepeats = Math.max(2, Math.ceil(count / 10));

      while (prompts.length < count && attempts < maxAttempts) {
        const prompt = createPrompt(prompts.length, attempts);
        attempts += 1;
        if (seen.has(prompt)) continue;
        const structureSignature = promptStructureSignature(prompt);
        const structureCount = structureCounts.get(structureSignature) || 0;
        if (structureCount >= maxStructureRepeats) continue;
        seen.add(prompt);
        structureCounts.set(structureSignature, structureCount + 1);
        prompts.push(prompt);
      }

      while (prompts.length < count && attempts < maxAttempts * 2) {
        const prompt = createPrompt(prompts.length, attempts);
        attempts += 1;
        if (seen.has(prompt)) continue;
        seen.add(prompt);
        prompts.push(prompt);
      }
      return prompts;
    };

    const buildPrompts = () => {
      const mode = byId('worksheet-mode').value;
      const level = byId('worksheet-level').value;
      const families = selectedFamilies();
      const style = byId('worksheet-style').value;
      const count = Number(byId('worksheet-count').value);
      const band = byId('worksheet-band').value || levelBands[level] || '2';
      const flowMode = byId('worksheet-flow-mode').value || 'balanced';
      const selectedSubmode = byId('worksheet-submode').value || 'auto';
      const adjustedBand = styleAdjustBand(style, band);
      const overallBandRange = parseBand(adjustedBand);
      const bank = fixedBanks[level] || {};
      const fixedPool = families.flatMap((family) => bank[family] || []).filter(Boolean);
      const fixedFamily = fixedPool.length ? fixedPool : bank.mixed || Object.values(bank)[0] || [];
      if (!fixedFamily.length) return [];
      if (mode === 'fixed') {
        resolvedWorksheetTarget = selectedSubmode;
        const cycled = [];
        while (cycled.length < count) cycled.push(...shuffle(fixedFamily));
        return cycled.slice(0, count);
      }
      if (mode === 'adaptive') {
        const weakAreas = readWeakAreas();
        const target = resolveAdaptiveTarget(weakAreas);
        const adaptiveFamily = target === 'multiplication'
          ? 'multiplication'
          : target === 'division'
            ? 'division'
            : target === 'mental'
              ? 'anzan'
              : target === 'complements'
                ? 'anzan'
                : families[0] || 'addition';
        const adaptiveSubmode = target === 'multiplication'
          ? 'place-shifts'
          : target === 'division'
            ? 'quotient-building'
            : target === 'mental'
              ? 'anzan-recall'
              : target === 'complements'
                ? 'complement-balance'
                : 'arithmetic-rhythm';
        resolvedWorksheetTarget = selectedSubmode === 'auto' ? adaptiveSubmode : selectedSubmode;
        return buildUniquePrompts(count, (index, attempt) => makeDynamicPrompt(level, adaptiveFamily, band, style, index + attempt, digitBandForProgress(overallBandRange, count, index, flowMode), resolvedWorksheetTarget));
      }
      resolvedWorksheetTarget = selectedSubmode;
      return buildUniquePrompts(count, (index, attempt) => makeDynamicPrompt(level, families[index % Math.max(1, families.length)] || 'addition', band, style, index + attempt, digitBandForProgress(overallBandRange, count, index, flowMode), selectedSubmode));
    };

    const renderSheet = () => {
      const prompts = buildPrompts();
      const orientation = byId('worksheet-orientation').value;
      const ledgerHead = byId('worksheet-ledger-head');
      const teacherMode = byId('worksheet-style').value === 'teacher';
      const adaptiveMode = byId('worksheet-mode').value === 'adaptive';
      const teacherNote = byId('teacher-note');
      const weakAreas = readWeakAreas();
      table.replaceChildren();
      table.className = orientation === 'vertical' ? 'worksheet-table vertical-table' : 'worksheet-table ledger-table';
      table.closest('.ledger-panel')?.classList.toggle('teacher-mode', teacherMode);
      teacherNote.hidden = !teacherMode;
      adaptiveNote.hidden = !adaptiveMode;
      adaptiveNoteCopy.textContent = describeWeakArea(weakAreas);
      ledgerHead.hidden = orientation === 'vertical';
      if (orientation === 'vertical') {
        const columns = 5;
        const perColumn = Math.ceil(prompts.length / columns);
        for (let c = 0; c < columns; c += 1) {
          const col = document.createElement('div');
          col.className = 'vertical-drill-column';
          prompts.slice(c * perColumn, (c + 1) * perColumn).forEach((prompt, index) => {
            const absoluteIndex = c * perColumn + index;
            const row = document.createElement('label');
            row.className = 'vertical-drill-row';
            row.innerHTML = `
              <span class="ledger-no">${absoluteIndex + 1}</span>
              ${renderVerticalPrompt(prompt)}
              <input class="input worksheet-input vertical-input" data-prompt="${prompt}" type="text" inputmode="numeric" placeholder="Write" />
              <small class="worksheet-feedback vertical-feedback"></small>
              <div class="worksheet-row-actions"><button type="button" class="mini-action" data-row-action="check">Check</button><button type="button" class="mini-action" data-row-action="reveal">Reveal</button></div>
            `;
            col.appendChild(row);
          });
          table.appendChild(col);
        }
      } else {
        prompts.forEach((prompt, index) => {
          const row = document.createElement('label');
          row.className = 'ledger-row worksheet-row';
          row.innerHTML = `
            <span class="ledger-no">${index + 1}</span>
            <span class="worksheet-prompt ledger-prompt">${prompt}</span>
            <input class="input worksheet-input ledger-input" data-prompt="${prompt}" type="text" inputmode="numeric" placeholder="Write" />
            <small class="worksheet-feedback ledger-feedback"></small>
            <div class="worksheet-row-actions"><button type="button" class="mini-action" data-row-action="check">Check</button><button type="button" class="mini-action" data-row-action="reveal">Reveal</button></div>
          `;
          table.appendChild(row);
        });
      }
      const familyLabel = selectedFamilies().join(', ') || 'addition';
      const levelLabel = byId('worksheet-level').value;
      const bandLabel = byId('worksheet-band').value;
      const flowLabel = byId('worksheet-flow-mode').value === 'ramp' ? 'ramp up' : 'balanced variety';
      const submodeLabel = byId('worksheet-submode').value || 'auto';
      const bandGuide = byId('worksheet-band-guide');
      const bandSummary = byId('worksheet-band-summary');
      const targetSummary = byId('worksheet-target-summary');
      byId('worksheet-title').textContent = `${levelLabel} ${familyLabel} ${orientation === 'vertical' ? 'columns' : 'ledger'} · ${bandLabel} digits`;
      byId('worksheet-count-badge').textContent = `${prompts.length} drills`;
      currentSetupCopy.textContent = `${levelLabel} · ${byId('worksheet-mode').value} · ${familyLabel} · ${bandLabel} digits · ${flowLabel} · ${submodeLabel} · ${orientation}`;
      if (bandGuide) bandGuide.textContent = `Every shown operand stays within ${bandLabel} digits. ${flowLabel === 'ramp up' ? 'The sheet starts easier and finishes denser.' : 'The sheet balances several prompt shapes across the full set.'}`;
      if (bandSummary) bandSummary.textContent = `Operand band: ${bandLabel} digits. Flow: ${flowLabel}. Families: ${familyLabel}.`;
      if (targetSummary) targetSummary.textContent = `Focus target: ${submodeLabel === 'auto' ? `auto -> ${resolvedWorksheetTarget}` : submodeLabel}.`;
      scoreCopy.textContent = teacherMode
        ? 'Teacher key mode is active. Print or reveal for guided review.'
        : adaptiveMode
        ? 'Adaptive mode favors your recent weak areas. Blank answers are skipped.'
        : 'No answers checked yet.';
      setMetric('worksheet-answered', 0);
      setMetric('worksheet-correct', 0);
      setMetric('worksheet-accuracy', '0%');
      setMetric('worksheet-completion', '0%');
    };

    const scoreSheet = (reveal = false) => {
      const inputs = Array.from(document.querySelectorAll('.worksheet-input'));
      let answered = 0;
      let correct = 0;
      inputs.forEach((input) => {
        const row = input.closest('.ledger-row, .vertical-drill-row');
        const expected = solvePrompt(input.dataset.prompt);
        const feedback = input.parentElement.querySelector('.worksheet-feedback');
        const value = input.value.trim();
        if (!value) {
          feedback.textContent = '';
          feedback.className = 'worksheet-feedback ledger-feedback';
          row?.classList.remove('row-ok', 'row-needs-work', 'row-revealed');
          return;
        }
        answered += 1;
        const isCorrect = Number(value) === expected;
        if (isCorrect) correct += 1;
        playTone(reveal ? 'success' : isCorrect ? 'success' : 'error');
        feedback.textContent = reveal ? `${expected}` : (isCorrect ? '✓' : '○');
        feedback.className = `worksheet-feedback ledger-feedback ${reveal ? 'revealed' : isCorrect ? 'ok' : 'needs-work'}`;
        row?.classList.remove('row-ok', 'row-needs-work', 'row-revealed');
        row?.classList.add(reveal ? 'row-revealed' : isCorrect ? 'row-ok' : 'row-needs-work');
      });
      if (!answered) {
        scoreCopy.textContent = reveal ? 'Answers revealed for answered rows only. Blank rows were skipped.' : 'No answered rows yet. Blank rows are skipped.';
        setMetric('worksheet-answered', 0);
        setMetric('worksheet-correct', 0);
        setMetric('worksheet-accuracy', '0%');
        setMetric('worksheet-completion', '0%');
        celebration.hidden = true;
        return;
      }
      const percent = Math.round((correct / answered) * 100);
      const completion = Math.round((answered / inputs.length) * 100);
      scoreCopy.textContent = `${correct}/${answered} correct · ${percent}% answered score · ${completion}% completion`;
      setMetric('worksheet-answered', answered);
      setMetric('worksheet-correct', correct);
      setMetric('worksheet-accuracy', `${percent}%`);
      setMetric('worksheet-completion', `${completion}%`);
      if (answered === inputs.length && correct === answered) {
        celebration.hidden = false;
        celebration.classList.add('celebrate');
        if (celebrationTimeout) window.clearTimeout(celebrationTimeout);
        celebrationTimeout = window.setTimeout(() => {
          celebration.hidden = true;
          celebration.classList.remove('celebrate');
        }, 6000);
      } else {
        celebration.hidden = true;
        celebration.classList.remove('celebrate');
      }
    };

    const applyWriteCellShortcut = (event) => {
      const input = event.target.closest('.worksheet-input');
      if (!(input instanceof HTMLInputElement) || event.metaKey || event.ctrlKey || event.altKey) return false;
      if (event.key === '*' || event.code === 'NumpadMultiply') {
        event.preventDefault();
        input.value = '';
        return true;
      }
      if (event.key === '-' || event.code === 'NumpadSubtract') {
        event.preventDefault();
        input.value = input.value.slice(0, -1);
        return true;
      }
      return false;
    };

    const scoreSingleRow = (row, reveal = false) => {
      const input = row.querySelector('.worksheet-input');
      const feedback = row.querySelector('.worksheet-feedback');
      if (!input || !feedback) return false;
      const expected = solvePrompt(input.dataset.prompt);
      const value = input.value.trim();
      if (!value) {
        feedback.textContent = reveal ? `${expected}` : 'Write first';
        feedback.className = `worksheet-feedback ${reveal ? 'revealed' : 'needs-work'}`;
        row.classList.remove('row-ok', 'row-needs-work', 'row-revealed');
        row.classList.add(reveal ? 'row-revealed' : 'row-needs-work');
        return false;
      }
      const isCorrect = Number(value) === expected;
      playTone(reveal ? 'success' : isCorrect ? 'success' : 'error');
      feedback.textContent = reveal ? `${expected}` : (isCorrect ? '✓' : '○');
      feedback.className = `worksheet-feedback ${reveal ? 'revealed' : isCorrect ? 'ok' : 'needs-work'}`;
      row.classList.remove('row-ok', 'row-needs-work', 'row-revealed');
      row.classList.add(reveal ? 'row-revealed' : isCorrect ? 'row-ok' : 'row-needs-work');
      return isCorrect;
    };

    const syncTimer = () => {
      if (!worksheetTimerStartedAt) return;
      const seconds = Math.max(0, Math.round((Date.now() - worksheetTimerStartedAt) / 1000));
      setMetric('worksheet-time', `${seconds}s`);
    };

    byId('worksheet-timer-toggle')?.addEventListener('click', () => {
      if (byId('worksheet-timer-mode').value === 'off') return;
      if (worksheetTimerStartedAt) {
        window.clearInterval(worksheetTimerInterval);
        worksheetTimerInterval = null;
        worksheetTimerStartedAt = null;
        byId('worksheet-timer-toggle').textContent = 'Start timer';
        return;
      }
      worksheetTimerStartedAt = Date.now();
      byId('worksheet-timer-toggle').textContent = 'Pause timer';
      syncTimer();
      worksheetTimerInterval = window.setInterval(syncTimer, 1000);
    });

    byId('worksheet-timer-mode')?.addEventListener('change', () => {
      if (byId('worksheet-timer-mode').value === 'off') {
        window.clearInterval(worksheetTimerInterval);
        worksheetTimerInterval = null;
        worksheetTimerStartedAt = null;
        byId('worksheet-timer-toggle').textContent = 'Start timer';
        setMetric('worksheet-time', '0s');
      }
    });

    byId('worksheet-level')?.addEventListener('change', () => {
      applyLevelDefaults();
      renderSheet();
    });
    byId('generate-worksheet')?.addEventListener('click', renderSheet);
    byId('check-worksheet')?.addEventListener('click', () => scoreSheet(false));
    byId('reveal-worksheet')?.addEventListener('click', () => scoreSheet(true));
    byId('teacher-key')?.addEventListener('click', () => {
      byId('worksheet-style').value = 'teacher';
      byId('worksheet-print-mode').value = 'answer-key';
      setPrintMode();
      renderSheet();
      scoreSheet(true);
    });
    byId('print-worksheet')?.addEventListener('click', () => {
      setPrintMode();
      if (byId('worksheet-print-mode').value === 'answer-key') {
        byId('worksheet-style').value = 'teacher';
        renderSheet();
        scoreSheet(true);
      }
      window.print();
    });
    document.querySelectorAll('input[name="worksheet-family"]').forEach((node) => {
      node.addEventListener('change', () => {
        autoAlignOrientation();
        renderSheet();
      });
    });
    document.querySelectorAll('[data-preset]').forEach((button) => {
      button.addEventListener('click', () => applyPreset(button.dataset.preset));
    });
    table.addEventListener('click', (event) => {
      const button = event.target.closest('[data-row-action]');
      if (!button) return;
      const row = button.closest('.ledger-row, .vertical-drill-row');
      if (!row) return;
      scoreSingleRow(row, button.dataset.rowAction === 'reveal');
    });
    table.addEventListener('keydown', (event) => {
      if (applyWriteCellShortcut(event)) return;
      if (event.key !== 'Enter') return;
      const input = event.target.closest('.worksheet-input');
      if (!input) return;
      event.preventDefault();
      const row = input.closest('.ledger-row, .vertical-drill-row');
      if (!row) return;
      if (!scoreSingleRow(row, false)) return;
      const inputs = Array.from(document.querySelectorAll('.worksheet-input'));
      const nextInput = inputs[inputs.indexOf(input) + 1];
      if (nextInput instanceof HTMLInputElement) nextInput.focus();
    });
    document.querySelectorAll('#worksheet-mode, #worksheet-level, #worksheet-family, #worksheet-band, #worksheet-style, #worksheet-orientation, #worksheet-count, #worksheet-flow-mode, #worksheet-submode, #worksheet-print-mode').forEach((node) => {
      node.addEventListener('change', renderSheet);
    });
    const initialPreset = new URLSearchParams(window.location.search).get('preset');
    if (initialPreset && presets[initialPreset]) {
      applyPreset(initialPreset);
    } else {
      applyLevelDefaults();
      renderSheet();
    }
    setPrintMode();
    setMetric('worksheet-time', '0s');
  </script>
</BaseLayout>
