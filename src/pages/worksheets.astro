---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const sections = [
  {
    title: 'Foundation sums',
    kind: 'Addition',
    rows: [
      ['1 + 2', '2 + 1', '2 + 2', '3 + 1', '4 + 1'],
      ['1 + 3', '2 + 3', '3 + 2', '4 + 2', '5 + 1'],
    ],
  },
  {
    title: 'Foundation subtraction',
    kind: 'Subtraction',
    rows: [
      ['4 - 1', '5 - 2', '6 - 1', '7 - 3', '8 - 2'],
      ['6 - 2', '7 - 1', '8 - 4', '9 - 3', '9 - 2'],
    ],
  },
  {
    title: 'Mixed two-digit drills',
    kind: 'Mixed',
    rows: [
      ['24 + 7', '31 - 4', '18 + 5', '42 - 11', '25 + 6'],
      ['36 - 12', '27 + 8', '44 - 9', '52 - 18', '19 + 14'],
    ],
  },
  {
    title: 'Multiplication patterns',
    kind: 'Multiplication',
    rows: [
      ['3 × 4', '4 × 3', '2 × 6', '5 × 2', '3 × 5'],
      ['6 × 2', '4 × 4', '3 × 6', '7 × 2', '5 × 3'],
    ],
  },
  {
    title: 'Division patterns',
    kind: 'Division',
    rows: [
      ['12 ÷ 3', '12 ÷ 4', '10 ÷ 2', '15 ÷ 3', '18 ÷ 6'],
      ['16 ÷ 4', '20 ÷ 5', '21 ÷ 3', '24 ÷ 6', '18 ÷ 3'],
    ],
  },
];
---

<BaseLayout title="Soroban Worksheets | Soroban Dojo">
  <section class="panel content-prose no-print">
    <p class="eyebrow">Soroban sheets · 印刷</p>
    <h1>Standard drill sheets</h1>
    <p>Work through multiple columns the way a traditional drill sheet feels: repeated arithmetic, quiet rhythm, then answer checking.</p>
    <div class="button-row">
      <button class="button" onclick="window.print()">Print sheet</button>
      <button class="button button-secondary" id="check-worksheet">Check answers</button>
      <button class="button button-secondary" id="reveal-worksheet">Reveal all answers</button>
      <a class="button button-secondary" href={`${base}practice`}>Return to practice</a>
    </div>
  </section>

  <section class="worksheet-board">
    {sections.map((section, sectionIndex) => (
      <article class="panel worksheet-panel">
        <div class="section-head">
          <div>
            <p class="eyebrow">{section.kind}</p>
            <h2>{section.title}</h2>
          </div>
          <span class="badge">{section.rows.flat().length} drills</span>
        </div>
        <div class="worksheet-table">
          {section.rows.map((row, rowIndex) => (
            <div class="worksheet-row">
              {row.map((prompt, promptIndex) => (
                <label class="worksheet-cell">
                  <span class="worksheet-prompt">{prompt}</span>
                  <input
                    class="input worksheet-input"
                    data-worksheet-section={sectionIndex}
                    data-worksheet-row={rowIndex}
                    data-worksheet-col={promptIndex}
                    type="text"
                    inputmode="numeric"
                    placeholder="Answer"
                  />
                  <small class="worksheet-feedback" data-worksheet-feedback={sectionIndex + '-' + rowIndex + '-' + promptIndex}></small>
                </label>
              ))}
            </div>
          ))}
        </div>
      </article>
    ))}
  </section>

  <script is:inline define:vars={{ sections }}>
    const solvePrompt = (prompt) => {
      const normalized = prompt.replace('×', '*').replace('÷', '/');
      const [left, operator, right] = normalized.split(' ');
      const a = Number(left);
      const b = Number(right);
      if (operator === '+') return a + b;
      if (operator === '-') return a - b;
      if (operator === '*') return a * b;
      if (operator === '/') return a / b;
      return null;
    };

    const allInputs = Array.from(document.querySelectorAll('.worksheet-input'));
    const getPrompt = (input) => {
      const sectionIndex = Number(input.dataset.worksheetSection);
      const rowIndex = Number(input.dataset.worksheetRow);
      const colIndex = Number(input.dataset.worksheetCol);
      return sections[sectionIndex].rows[rowIndex][colIndex];
    };

    document.getElementById('check-worksheet')?.addEventListener('click', () => {
      allInputs.forEach((input) => {
        const prompt = getPrompt(input);
        const expected = solvePrompt(prompt);
        const feedback = document.querySelector(`[data-worksheet-feedback="${input.dataset.worksheetSection}-${input.dataset.worksheetRow}-${input.dataset.worksheetCol}"]`);
        const correct = input.value.trim() !== '' && Number(input.value) === expected;
        feedback.textContent = correct ? '✓ correct' : 'Check again';
        feedback.className = `worksheet-feedback ${correct ? 'ok' : 'needs-work'}`;
      });
    });

    document.getElementById('reveal-worksheet')?.addEventListener('click', () => {
      allInputs.forEach((input) => {
        const prompt = getPrompt(input);
        const expected = solvePrompt(prompt);
        input.value = String(expected);
        const feedback = document.querySelector(`[data-worksheet-feedback="${input.dataset.worksheetSection}-${input.dataset.worksheetRow}-${input.dataset.worksheetCol}"]`);
        feedback.textContent = `Answer: ${expected}`;
        feedback.className = 'worksheet-feedback revealed';
      });
    });
  </script>
</BaseLayout>
