---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Support | Soroban Dojo">
  <section class="panel content-prose support-card">
    <p class="eyebrow">Support the dojo</p>
    <h1>Help keep practical Soroban lessons free</h1>
    <p>Your support helps fund more lessons, more exercises, better explanations, and calmer study tools for children and adults.</p>
    <div class="hero-actions">
      <a class="button" href="https://buy.stripe.com/8x200i8bSgVe3Vl3g8bfO00" target="_blank" rel="noreferrer">Donate via Stripe</a>
    </div>
    <p class="muted">Once the repository URL is published, add it here so contributors can open issues and pull requests directly from the support page.</p>
  </section>
</BaseLayout>
