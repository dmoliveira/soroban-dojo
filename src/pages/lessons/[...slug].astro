---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LessonMiniCheck from '../../components/LessonMiniCheck.astro';
import SorobanVisualizer from '../../components/SorobanVisualizer.astro';
import { numberToKanji } from '../../lib/japanese';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons');
  return lessons.map((lesson) => ({ params: { slug: lesson.slug }, props: { lesson } }));
}

const { lesson } = Astro.props;
const { Content } = await render(lesson);
const allLessons = await getCollection('lessons');
const relatedExercises = (await getCollection('exercises'))
  .filter((entry) => lesson.data.relatedExercises.includes(entry.data.id))
  .sort((a, b) => lesson.data.relatedExercises.indexOf(a.data.id) - lesson.data.relatedExercises.indexOf(b.data.id));
const prerequisiteLesson = allLessons.find((entry) => lesson.data.prerequisites.includes(entry.data.id));
const nextLessons = allLessons
  .filter((entry) => lesson.data.nextLessons.includes(entry.data.id))
  .sort((a, b) => lesson.data.nextLessons.indexOf(a.data.id) - lesson.data.nextLessons.indexOf(b.data.id));
const recommendedNextLesson = nextLessons[0] ?? null;
const recommendedExercise = relatedExercises[0] ?? null;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const worksheetPreset = lesson.data.level === 'L4' && lesson.data.skill === 'multiplication'
  ? 'multiplication-focus'
  : lesson.data.level === 'L4' && lesson.data.skill === 'division'
    ? 'division-focus'
    : lesson.data.level === 'L5'
      ? 'anzan-focus'
      : lesson.data.skill === 'complements'
        ? 'complements'
        : null;
const worksheetActions = lesson.data.skill === 'multiplication'
  ? [
      { label: 'Table-family worksheet', href: `${base}worksheets?preset=multiplication-focus&submode=table-family` },
      { label: 'Place-shift worksheet', href: `${base}worksheets?preset=multiplication-focus&submode=place-shifts` },
    ]
  : lesson.data.skill === 'division'
    ? [
        { label: 'Division-facts worksheet', href: `${base}worksheets?preset=division-focus&submode=division-facts` },
        { label: 'Quotient-building worksheet', href: `${base}worksheets?preset=division-focus&submode=quotient-building` },
      ]
    : lesson.data.skill === 'anzan' || lesson.data.skill === 'mastery'
      ? [
          { label: 'Mental recall worksheet', href: `${base}worksheets?preset=anzan-focus&submode=anzan-recall` },
        ]
      : [];
const lessonMiniChecks = ({
  'lesson-l4-001': {
    title: 'Mini checks for first multiplication',
    prompt: 'What is 3 × 4?',
    answer: '12',
    inputMode: 'numeric',
    items: [
      'If each group is 4 and you need 3 groups, what totals should you read after each step?',
      'Which feels cleaner to you on the soroban: 3 × 4 or 4 × 3?',
      'If the multiplier becomes larger, what becomes more important: speed or stable re-reading?',
    ],
  },
  'lesson-l4-005': {
    title: 'Mini checks for place shifts',
    prompt: 'What is 12 × 3?',
    answer: '36',
    inputMode: 'numeric',
    items: [
      'In 13 × 5, which partial product should you think first?',
      'Why is 10 × 4 not the same kind of result as 4 × 4?',
      'If the tens place product is already correct, what should the ones place addition avoid changing?',
    ],
  },
  'lesson-l4-002': {
    title: 'Mini checks for first division',
    prompt: 'What is 12 ÷ 3?',
    answer: '4',
    inputMode: 'numeric',
    items: [
      'In 12 ÷ 3, what multiplication fact should appear immediately?',
      'In 12 ÷ 4, why is 3 the quotient instead of 4?',
      'Which is more stable for you right now: equal groups or missing-factor thinking?',
    ],
  },
  'lesson-l4-006': {
    title: 'Mini checks for quotient building',
    prompt: 'What is 24 ÷ 6?',
    answer: '4',
    inputMode: 'numeric',
    items: [
      'In 24 ÷ 6, what multiplication fact proves the answer?',
      'In 36 ÷ 9, why is the quotient not 9?',
      'When the quotient feels uncertain, what is the fastest safe check?',
    ],
  },
  'lesson-l5-001': {
    title: 'Mini checks for mental sequences',
    prompt: 'What is 18 + 7 - 4 + 5?',
    answer: '26',
    inputMode: 'numeric',
    items: [
      'In 18 + 7 - 4 + 5, which total should be held before the final step?',
      'Why is it safer to re-read 21 before adding 5?',
      'If you lose the total after a subtraction, what should you rebuild first?',
    ],
  },
  'lesson-l5-002': {
    title: 'Mini checks for speed control',
    prompt: 'What is 74 + 8 - 3 + 12?',
    answer: '91',
    inputMode: 'numeric',
    items: [
      'After 74 + 8, what total must stay clear before the subtraction begins?',
      'Why is 79 the most important checkpoint in the worked example?',
      'When the rhythm feels unstable, what should you protect first: speed or the full running total?',
    ],
  },
} as const)[lesson.data.id] ?? null;
const bestFor = lesson.data.skill === 'abacus-orientation'
  ? 'Best for first contact with the soroban, naming the parts, and building calm familiarity.'
  : lesson.data.skill === 'number-reading' || lesson.data.skill === 'place-value'
    ? 'Best for reading structure accurately before moving into longer arithmetic drills.'
    : lesson.data.skill === 'addition' || lesson.data.skill === 'subtraction'
      ? 'Best for building confident arithmetic rhythm before moving into mixed worksheets.'
      : lesson.data.skill === 'complements'
        ? 'Best for strengthening number balance and cleaner movement on the soroban.'
        : 'Best for guided progression in this stage of practice.';
---

<BaseLayout title={`${lesson.data.title} | Soroban Dojo`} description={lesson.data.summary}>
  <article class="panel content-prose lesson-page-panel">
    <p class="eyebrow">Lesson · {lesson.data.level}</p>
    <h1>{lesson.data.title}</h1>
    <div class="meta-row">
      <span>{lesson.data.skill}</span>
      <span>{lesson.data.estimatedMinutes} min</span>
      <span>{lesson.data.audience.join(', ')}</span>
      {lesson.data.visualValue !== undefined && <span>数 {numberToKanji(lesson.data.visualValue)}</span>}
    </div>
    <div class="lesson-utility-row">
      <a class="text-link" href={`${base}lessons`}>All lessons</a>
      <a class="text-link" href={`${base}levels/${lesson.data.level.toLowerCase()}`}>This level</a>
      <a class="text-link" href={`${base}worksheets`}>Worksheet</a>
    </div>
    <section class="lesson-facts-grid">
      <article class="stat-card stat-card-soft"><span>{lesson.data.level}</span><small>Level</small></article>
      <article class="stat-card stat-card-soft"><span>{lesson.data.skill}</span><small>Skill</small></article>
      <article class="stat-card stat-card-soft"><span>{lesson.data.estimatedMinutes}m</span><small>Time</small></article>
      <article class="stat-card stat-card-soft"><span>{lesson.data.audience.join('/')}</span><small>Audience</small></article>
      {prerequisiteLesson && <article class="stat-card stat-card-soft"><span>{prerequisiteLesson.data.title}</span><small>Prerequisite</small></article>}
    </section>
    <div class="subtle-panel lesson-best-for-panel">
      <strong>Best for</strong>
      <p class="muted">{bestFor}</p>
    </div>
    <nav class="lesson-nav-strip" aria-label="Lesson sections">
      <a href="#lesson-core">Core idea</a>
      <a href="#lesson-objectives">Objectives</a>
      {lesson.data.visualValue !== undefined && <a href="#lesson-visual">Worked example</a>}
      <a href="#lesson-content">Lesson</a>
      <a href="#lesson-next">Next step</a>
      <a href="#lesson-exercises">Exercises</a>
    </nav>
    <div class="review-chip-row lesson-flow-strip">
      <span class="review-chip">1. Read the core idea</span>
      <span class="review-chip">2. Study the worked example</span>
      <span class="review-chip">3. Practice the related drills</span>
    </div>
    <div class="lesson-summary-grid">
      <section id="lesson-core" class="subtle-panel lesson-summary-panel">
        <p class="eyebrow">Core idea</p>
        <p>{lesson.data.summary}</p>
        <div class="button-row">
          <button class="button button-secondary lesson-complete-toggle" data-lesson-id={lesson.data.id}>Mark lesson complete</button>
          <a class="button button-secondary" href={`${base}progress`}>View progress</a>
        </div>
        <div id="lesson-complete-next" class="lesson-complete-next subtle-panel" hidden>
          <strong>Completed. Continue with the next move.</strong>
          <div class="button-row lesson-complete-actions">
            {recommendedNextLesson && <a class="button button-secondary" href={`${base}lessons/${recommendedNextLesson.slug}`}>Next lesson</a>}
            {recommendedExercise && <a class="button button-secondary" href={`${base}exercises/${recommendedExercise.slug}`}>Next exercise</a>}
            <a class="button button-secondary" href={worksheetPreset ? `${base}worksheets?preset=${worksheetPreset}` : `${base}worksheets`}>Matching worksheet</a>
          </div>
        </div>
      </section>
      <section id="lesson-objectives" class="subtle-panel lesson-summary-panel">
        <p class="eyebrow">Objectives</p>
        <ul>
          {lesson.data.objectives.map((objective) => <li>{objective}</li>)}
        </ul>
      </section>
    </div>
    {lesson.data.visualValue !== undefined && (
      <div id="lesson-visual">
      <SorobanVisualizer value={lesson.data.visualValue} stepValues={lesson.data.stepValues} label={`Worked visual for ${lesson.data.title}`} />
      </div>
    )}
    {lessonMiniChecks && (
      <LessonMiniCheck title={lessonMiniChecks.title} prompt={lessonMiniChecks.prompt} answer={lessonMiniChecks.answer} inputMode={lessonMiniChecks.inputMode}>
        <ul>
          {lessonMiniChecks.items.map((item) => <li>{item}</li>)}
        </ul>
      </LessonMiniCheck>
    )}
    <div id="lesson-content">
      <Content components={{ LessonMiniCheck }} />
    </div>
    <section id="lesson-next" class="panel lesson-next-panel">
      <p class="eyebrow">Next step</p>
      <h2>Continue with guided practice</h2>
      <div class="button-row">
        <a class="button" href={`${base}practice`}>Practice this level</a>
        <a class="button button-secondary" href={worksheetPreset ? `${base}worksheets?preset=${worksheetPreset}` : `${base}worksheets`}>Open worksheet</a>
        {worksheetActions.map((action) => <a class="button button-secondary" href={action.href}>{action.label}</a>)}
        {prerequisiteLesson && (
          <a class="button button-secondary" href={`${base}lessons/${prerequisiteLesson.slug}`}>Review prerequisite</a>
        )}
      </div>
      <p class="muted">Use practice mode for immediate repetition, or open worksheets for denser drill sets tied to this level and skill.</p>
    </section>
    {(prerequisiteLesson || nextLessons.length) && (
      <section class="split-grid lesson-nav-grid">
        {prerequisiteLesson && (
          <article class="panel">
            <p class="eyebrow">Previous lesson</p>
            <h2>{prerequisiteLesson.data.title}</h2>
            <p>{prerequisiteLesson.data.summary}</p>
            <a class="text-link" href={`${base}lessons/${prerequisiteLesson.slug}`}>Open previous lesson →</a>
          </article>
        )}
        {nextLessons.map((nextLesson) => (
          <article class="panel">
            <p class="eyebrow">Next lesson</p>
            <h2>{nextLesson.data.title}</h2>
            <p>{nextLesson.data.summary}</p>
            <a class="text-link" href={`${base}lessons/${nextLesson.slug}`}>Open next lesson →</a>
          </article>
        ))}
      </section>
    )}
    <h2 id="lesson-exercises">Related exercises</h2>
    <ul class="list-clean">
      {relatedExercises.map((exercise) => (
        <li>
          <strong>{exercise.data.title}</strong>
          <div class="meta-row">
            <span>{exercise.data.level}</span>
            <span>{exercise.data.skill}</span>
            <span>{exercise.data.estimatedMinutes} min</span>
          </div>
          <p>{exercise.data.explanation}</p>
          <a class="text-link" href={`${base}exercises/${exercise.slug}`}>Try exercise →</a>
        </li>
      ))}
    </ul>
  </article>

  <script is:inline define:vars={{ lessonId: lesson.data.id }}>
    const lessonKey = 'soroban-dojo:completed-lessons';
    const button = document.querySelector('.lesson-complete-toggle');
    const nextPanel = document.getElementById('lesson-complete-next');
    const readLessons = () => {
      try {
        return JSON.parse(localStorage.getItem(lessonKey) || '[]');
      } catch {
        return [];
      }
    };
    const syncLabel = () => {
      const current = readLessons();
      const done = current.includes(lessonId);
      button.textContent = done ? 'Lesson completed' : 'Mark lesson complete';
      button.setAttribute('aria-pressed', String(done));
      if (nextPanel) nextPanel.hidden = !done;
    };
    button?.addEventListener('click', () => {
      const current = readLessons();
      const next = current.includes(lessonId) ? current.filter((entry) => entry !== lessonId) : [...current, lessonId];
      localStorage.setItem(lessonKey, JSON.stringify(next));
      syncLabel();
    });
    syncLabel();
  </script>
</BaseLayout>
