---
import { getCollection } from 'astro:content';
import Hero from '../components/Hero.astro';
import PathCards from '../components/PathCards.astro';
import LevelGrid from '../components/LevelGrid.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const lessons = (await getCollection('lessons')).slice(0, 3);
const exercises = (await getCollection('exercises')).slice(0, 3);
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Soroban Dojo" description="GitHub Pages-ready Soroban learning with calm lessons and attempt-first practice.">
  <Hero
    eyebrow="GitHub Pages-ready Soroban dojo"
    title="Learn with calm structure. Practice with steady discipline."
    summary="A local-first Soroban learning site for children and adults: lessons, attempt-first exercises, timed practice, progress that stays in your browser, and a quiet Japanese dojo atmosphere."
  />

  <PathCards />

  <section class="split-grid">
    <article class="panel">
      <p class="eyebrow">Approach</p>
      <h2>Japanese dojo principles</h2>
      <ul class="list-clean">
        <li><strong>Shoshin:</strong> begin openly and repeat without shame.</li>
        <li><strong>Kaizen:</strong> improve through small, daily practice.</li>
        <li><strong>Ma:</strong> keep the learning space quiet and clear.</li>
        <li><strong>Kintsugi:</strong> review mistakes as part of mastery.</li>
        <li><strong>Rei:</strong> keep the interface respectful, calm, and precise.</li>
      </ul>
    </article>
    <article class="panel support-card">
      <p class="eyebrow">Today’s path</p>
      <h2>Start with one clear step</h2>
      <p>Pick a path, learn one concept, then try one exercise before checking the answer.</p>
      <div class="hero-actions">
        <a class="button" href={`${base}practice`}>Practice now</a>
        <a class="button button-secondary" href={`${base}support`}>Support the dojo</a>
        <a class="button button-secondary" href={`${base}daily-drills`}>Daily drills</a>
      </div>
    </article>
  </section>

  <section class="split-grid">
    <article class="panel">
      <p class="eyebrow">Printable practice</p>
      <h2>Offline worksheet mode</h2>
      <p>Print calm practice sheets for desk work, parent-guided review, or dojo repetition away from the screen.</p>
      <a class="text-link" href={`${base}worksheets`}>Open worksheets →</a>
    </article>
    <article class="panel">
      <p class="eyebrow">Daily training</p>
      <h2>Fresh drill pack each day</h2>
      <p>Generate a stable daily set by level and print it if you want a paper routine.</p>
      <a class="text-link" href={`${base}daily-drills`}>Open daily drills →</a>
    </article>
  </section>

  <section class="panel">
    <p class="eyebrow">Levels</p>
    <h2>Move from first beads to mental soroban</h2>
    <LevelGrid />
  </section>

  <section class="split-grid">
    <article class="panel">
      <p class="eyebrow">Featured lessons</p>
      <h2>Begin with guided lessons</h2>
      <ul class="list-clean">
        {lessons.map((lesson) => (
          <li>
            <strong>{lesson.data.title}</strong>
            <div class="meta-row">
              <span>{lesson.data.level}</span>
              <span>{lesson.data.skill}</span>
              <span>{lesson.data.estimatedMinutes} min</span>
            </div>
            <p>{lesson.data.summary}</p>
            <a class="text-link" href={`${base}lessons/${lesson.slug}`}>Open lesson →</a>
          </li>
        ))}
      </ul>
    </article>
    <article class="panel">
      <p class="eyebrow">Practice library</p>
      <h2>Try one and then compare</h2>
      <ul class="list-clean">
        {exercises.map((exercise) => (
          <li>
            <strong>{exercise.data.title}</strong>
            <div class="meta-row">
              <span>{exercise.data.level}</span>
              <span>{exercise.data.skill}</span>
              <span>{exercise.data.estimatedMinutes} min</span>
            </div>
            <p>{exercise.data.explanation}</p>
            <a class="text-link" href={`${base}exercises/${exercise.slug}`}>Open exercise →</a>
          </li>
        ))}
      </ul>
    </article>
  </section>
</BaseLayout>
