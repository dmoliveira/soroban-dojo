---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy | Soroban Dojo">
  <section class="panel content-prose">
    <p class="eyebrow">Privacy</p>
    <h1>Your progress stays in your browser</h1>
    <p>The MVP stores lesson completion, exercise review states, and timer history in browser storage on your device.</p>
    <ul>
      <li>No account is required.</li>
      <li>No hidden analytics are enabled in this MVP.</li>
      <li>You can clear progress from the Progress page at any time.</li>
    </ul>
  </section>
</BaseLayout>
